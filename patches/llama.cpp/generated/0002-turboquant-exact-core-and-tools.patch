+struct cuda_buffer {
+    void * ptr = nullptr;
+
+    void reset() {
+        if (ptr != nullptr) {
+            cudaFree(ptr);
+            ptr = nullptr;
+        }
+    }
+
+    ~cuda_buffer() {
+        reset();
+    }
+
+    cuda_buffer(const cuda_buffer &) = delete;
+    cuda_buffer & operator=(const cuda_buffer &) = delete;
+    cuda_buffer() = default;
+    cuda_buffer(cuda_buffer && other) noexcept : ptr(other.ptr) {
+        other.ptr = nullptr;
+    }
+    cuda_buffer & operator=(cuda_buffer && other) noexcept {
+        if (this != &other) {
+            reset();
+            ptr = other.ptr;
+            other.ptr = nullptr;
+        }
+        return *this;
+    }
+};
