+struct turboquant_exact_cache_key_hash {
+    size_t operator()(const turboquant_exact_cache_key & key) const noexcept {
+        size_t h = std::hash<const void *>{}(key.data);
+        h ^= std::hash<int>{}(key.dim) + 0x9e3779b9 + (h << 6) + (h >> 2);
+        h ^= std::hash<int>{}(key.bits) + 0x9e3779b9 + (h << 6) + (h >> 2);
+        h ^= std::hash<int>{}(key.qjl_dim) + 0x9e3779b9 + (h << 6) + (h >> 2);
+        h ^= std::hash<int>{}(key.outlier_channels) + 0x9e3779b9 + (h << 6) + (h >> 2);
+        h ^= std::hash<int>{}(key.n_head_k) + 0x9e3779b9 + (h << 6) + (h >> 2);
+        h ^= std::hash<int>{}(key.n_stream) + 0x9e3779b9 + (h << 6) + (h >> 2);
+        return h;
