+struct turboquant_packed_layout {
+    int index_bytes = 0;
+    int vec_norm_offset = 0;
+    int residual_norm_offset = 0;
+    int sign_words_offset = 0;
+    int outlier_indices_offset = 0;
+    int outlier_values_offset = 0;
+    int packed_bytes = 0;
+    int mse_bits = 0;
+};
+
+static turboquant_packed_layout make_turboquant_packed_layout(int dim, int mse_bits, int qjl_dim, int outlier_channels) {
+    turboquant_packed_layout layout;
+    const int n_sign_words = (qjl_dim + 31) / 32;
+    layout.mse_bits = mse_bits;
+    layout.index_bytes = turboquant_index_bytes_for_bits(dim, mse_bits);
+    layout.vec_norm_offset = align_up_int(layout.index_bytes, 4);
+    layout.residual_norm_offset = layout.vec_norm_offset + int(sizeof(float));
+    layout.sign_words_offset = align_up_int(layout.residual_norm_offset + int(sizeof(float)), 4);
+    layout.outlier_indices_offset = layout.sign_words_offset + n_sign_words * int(sizeof(uint32_t));
+    layout.outlier_values_offset = align_up_int(layout.outlier_indices_offset + outlier_channels * int(sizeof(uint16_t)), 4);
+    layout.packed_bytes = layout.outlier_values_offset + outlier_channels * int(sizeof(float));
+    return layout;
+}
