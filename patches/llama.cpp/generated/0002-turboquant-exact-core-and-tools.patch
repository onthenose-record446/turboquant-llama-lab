+int main(int argc, char ** argv) {
+    try {
+        const bench_args args = parse_args(argc, argv);
+
+        turboquant_init_params params;
+        params.dim = args.dim;
+        params.bits = args.bits;
+        params.qjl_dim = args.qjl_dim;
+        params.seed = static_cast<uint64_t>(args.seed);
+        params.codebook_iters = args.codebook_iters;
+        params.codebook_grid = args.codebook_grid;
+
+        const auto dataset = make_vectors(args.samples, args.dim, params.seed + 1);
+        const auto queries = make_vectors(args.queries, args.dim, params.seed + 2);
+
+        turboquant_mse mse_quant(params);
+        turboquant_init_params prod_mse_params = params;
+        prod_mse_params.bits = std::max(1, args.bits - 1);
+        turboquant_mse prod_mse_quant(prod_mse_params);
+        turboquant_prod prod_quant(params);
+
+        const auto mse_metrics = turboquant_score_mse(mse_quant, dataset);
+        const auto prod_mse_metrics = turboquant_score_mse(prod_mse_quant, dataset);
+        const auto prod_reference_ip_metrics = turboquant_score_mse_inner_products(prod_mse_quant, dataset, queries);
+        const auto prod_metrics = turboquant_score_prod(prod_quant, dataset, queries);
+
+        std::cout
+            << "{"
+            << "\"dim\":" << args.dim << ","
+            << "\"bits\":" << args.bits << ","
+            << "\"prod_mse_bits\":" << std::max(1, args.bits - 1) << ","
+            << "\"qjl_dim\":" << (args.qjl_dim > 0 ? args.qjl_dim : args.dim) << ","
+            << "\"samples\":" << args.samples << ","
+            << "\"queries\":" << args.queries << ","
+            << "\"mse_stage\":" << turboquant_metrics_json(mse_metrics) << ","
+            << "\"prod_reference_mse_stage\":" << turboquant_metrics_json(prod_mse_metrics) << ","
+            << "\"prod_reference_ip_stage\":" << turboquant_metrics_json(prod_reference_ip_metrics) << ","
+            << "\"prod_stage\":" << turboquant_metrics_json(prod_metrics)
+            << "}\n";
+
+        return 0;
+    } catch (const std::exception & exc) {
+        std::fprintf(stderr, "llama-turboquant-bench: %s\n", exc.what());
+        return 1;
+    }
+}
diff --git a/tools/turboquant-probe/turboquant-probe.cpp b/tools/turboquant-probe/turboquant-probe.cpp
new file mode 100644
index 0000000..d9a79b7
--- /dev/null
+++ b/tools/turboquant-probe/turboquant-probe.cpp
@@ -0,0 +1,466 @@
+#include "arg.h"
+#include "common.h"
+#include "ggml.h"
+#include "llama.h"
+#include "turboquant.h"
+#include "turboquant-probe-cuda.h"
+
+#include <algorithm>
+#include <cstdint>
+#include <cstdio>
+#include <cstdlib>
+#include <cstring>
+#include <mutex>
+#include <stdexcept>
+#include <string>
+#include <utility>
+#include <vector>
+
+using namespace llama_lab;
+
+namespace {
+
+struct probe_args {
+    int layer = 0;
+    int bits = 4;
+    int qjl_dim = 0;
+    int max_vectors = 512;
+    int max_prompt_tokens = 256;
+    int probe_ctx = 1024;
+    bool use_gpu = true;
+    bool use_cuda_exact = true;
+};
+
+struct captured_tensor {
+    std::string name;
+    std::vector<std::vector<float>> vectors;
+    std::vector<char> raw;
+    int64_t ne[4] = {0, 0, 0, 0};
+    size_t nb[4] = {0, 0, 0, 0};
+    ggml_type type = GGML_TYPE_COUNT;
+};
+
+struct probe_collector {
+    std::mutex mutex;
+    std::string q_name;
+    std::string k_name;
+    int max_vectors = 0;
+    captured_tensor q_capture;
+    captured_tensor k_capture;
+    std::vector<std::string> seen_names;
+
+    static std::string normalize_name(const char * raw_name) {
+        if (raw_name == nullptr) {
+            return {};
+        }
+        std::string name = raw_name;
+        const char * p = std::strchr(raw_name, '#');
+        if (p != nullptr) {
+            p += 1;
+            const char * q = std::strchr(p, '#');
+            if (q != nullptr) {
+                name.assign(p, q - p);
+            } else {
+                name.assign(p);
+            }
+        }
+        return name;
+    }
+
+    bool wants(const ggml_tensor * t) const {
+        if (t->name[0] == '\0') {
+            return false;
+        }
+        const std::string name = normalize_name(t->name);
+        return q_name == name || k_name == name;
+    }
+};
+
+static float tensor_scalar_to_f32(const char * base, ggml_type type, int64_t element_idx) {
+    switch (type) {
+        case GGML_TYPE_F32:
+            return reinterpret_cast<const float *>(base)[element_idx];
+        case GGML_TYPE_F16:
+            return ggml_fp16_to_fp32(reinterpret_cast<const ggml_fp16_t *>(base)[element_idx]);
+        case GGML_TYPE_BF16:
+            return ggml_bf16_to_fp32(reinterpret_cast<const ggml_bf16_t *>(base)[element_idx]);
+        default:
+            throw std::runtime_error(std::string("unsupported tensor type for probe: ") + ggml_type_name(type));
+    }
+}
+
+static std::vector<std::vector<float>> unpack_attention_vectors(
+        const captured_tensor & t,
+        int max_vectors,
+        int expected_head_dim = 0) {
+    if (t.ne[0] <= 0 || t.ne[1] <= 0) {
+        throw std::runtime_error("unexpected tensor shape for TurboQuant probe");
+    }
+
+    int dim = static_cast<int>(t.ne[0]);
+    int heads = static_cast<int>(std::max<int64_t>(1, t.ne[1]));
+    int tokens = static_cast<int>(std::max<int64_t>(1, t.ne[2]));
+    int streams = static_cast<int>(std::max<int64_t>(1, t.ne[3]));
+
+    bool merged_kv = false;
+    if (expected_head_dim > 0 && t.ne[2] == 1 && t.ne[3] == 1 && t.ne[0] % expected_head_dim == 0) {
+        dim = expected_head_dim;
+        heads = static_cast<int>(t.ne[0] / expected_head_dim);
+        tokens = static_cast<int>(t.ne[1]);
+        streams = 1;
+        merged_kv = true;
+    }
+
+    std::vector<std::vector<float>> out;
+    out.reserve(std::min(max_vectors, heads * tokens * streams));
+
+    const char * base = t.raw.data();
+    for (int s = 0; s < streams && (int) out.size() < max_vectors; ++s) {
+        for (int tok = 0; tok < tokens && (int) out.size() < max_vectors; ++tok) {
+            for (int head = 0; head < heads && (int) out.size() < max_vectors; ++head) {
+                std::vector<float> vec(dim);
+                for (int d = 0; d < dim; ++d) {
+                    int64_t offset = 0;
+                    if (merged_kv) {
+                        offset =
+                                (head * dim + d) * t.nb[0] +
+                                tok * t.nb[1];
+                    } else {
+                        offset =
+                                d * t.nb[0] +
+                                head * t.nb[1] +
+                                tok * t.nb[2] +
+                                s * t.nb[3];
+                    }
+                    vec[d] = tensor_scalar_to_f32(base + offset, t.type, 0);
+                }
+                out.push_back(std::move(vec));
+            }
+        }
+    }
+
+    return out;
+}
+
+static bool turboquant_probe_eval(struct ggml_tensor * t, bool ask, void * user_data) {
+    auto * collector = static_cast<probe_collector *>(user_data);
+    const std::string normalized_name = probe_collector::normalize_name(t->name);
+    if (ask) {
+        if (!normalized_name.empty() && collector->seen_names.size() < 128) {
+            if (std::find(collector->seen_names.begin(), collector->seen_names.end(), normalized_name) == collector->seen_names.end()) {
+                collector->seen_names.push_back(normalized_name);
+            }
+        }
+        return collector->wants(t);
+    }
+
+    if (!collector->wants(t)) {
+        return false;
+    }
+
+    std::lock_guard<std::mutex> lock(collector->mutex);
+    captured_tensor * dst = nullptr;
+
+    if (collector->q_name == normalized_name && collector->q_capture.vectors.empty()) {
+        dst = &collector->q_capture;
+    } else if (collector->k_name == normalized_name && collector->k_capture.vectors.empty()) {
+        dst = &collector->k_capture;
+    } else {
+        return true;
+    }
+
+    dst->name = normalized_name;
+    for (int i = 0; i < 4; ++i) {
+        dst->ne[i] = t->ne[i];
+        dst->nb[i] = t->nb[i];
+    }
+    dst->type = t->type;
+
+    std::vector<char> raw(ggml_nbytes(t));
+    if (ggml_backend_buffer_is_host(t->buffer)) {
+        std::memcpy(raw.data(), t->data, raw.size());
+    } else {
+        ggml_backend_tensor_get(t, raw.data(), 0, raw.size());
+    }
+    dst->raw = std::move(raw);
+    return true;
+}
+
+static void print_usage(int, char ** argv) {
+    std::fprintf(stderr,
+        "usage: %s -m model.gguf [-p prompt] [--layer N] [--bits N] [--qjl-dim N]\n"
+        "          [--max-vectors N] [--max-prompt-tokens N] [--probe-ctx N] [--cpu-only]\n",
+        argv[0]);
+}
+
+static bool parse_int_flag(const char * value, int & out) {
+    char * end = nullptr;
+    const long parsed = std::strtol(value, &end, 10);
+    if (end == nullptr || *end != '\0') {
+        return false;
+    }
+    out = static_cast<int>(parsed);
+    return true;
+}
+
+static std::vector<float> flatten_vectors(const std::vector<std::vector<float>> & vectors, int expected_dim) {
+    std::vector<float> out;
+    out.reserve(vectors.size() * std::max(expected_dim, 0));
+    for (const auto & vec : vectors) {
+        if ((int) vec.size() != expected_dim) {
+            throw std::runtime_error("TurboQuant vector flatten dimension mismatch");
+        }
+        out.insert(out.end(), vec.begin(), vec.end());
+    }
+    return out;
+}
+
+static std::pair<common_params, probe_args> parse_args(int argc, char ** argv) {
+    std::vector<char *> forwarded;
+    forwarded.reserve(argc);
+    forwarded.push_back(argv[0]);
+
+    probe_args probe;
+    for (int i = 1; i < argc; ++i) {
+        const std::string arg = argv[i];
+        auto need_value = [&](int & slot) {
+            if (i + 1 >= argc || !parse_int_flag(argv[++i], slot)) {
+                throw std::runtime_error("invalid value for " + arg);
+            }
+        };
+
+        if (arg == "--layer") {
+            need_value(probe.layer);
+        } else if (arg == "--bits") {
+            need_value(probe.bits);
+        } else if (arg == "--qjl-dim") {
+            need_value(probe.qjl_dim);
+        } else if (arg == "--max-vectors") {
+            need_value(probe.max_vectors);
+        } else if (arg == "--max-prompt-tokens") {
+            need_value(probe.max_prompt_tokens);
+        } else if (arg == "--probe-ctx") {
+            need_value(probe.probe_ctx);
+        } else if (arg == "--cpu-only") {
+            probe.use_gpu = false;
+            probe.use_cuda_exact = false;
+        } else if (arg == "--no-cuda-exact") {
+            probe.use_cuda_exact = false;
+        } else {
+            forwarded.push_back(argv[i]);
+        }
+    }
+
+    common_params params;
+    const int forwarded_argc = static_cast<int>(forwarded.size());
+    if (!common_params_parse(forwarded_argc, forwarded.data(), params, LLAMA_EXAMPLE_COMMON, print_usage)) {
+        throw std::runtime_error("failed to parse common llama.cpp arguments");
+    }
+
+    if (params.model.path.empty()) {
+        throw std::runtime_error("model path is required");
+    }
+
+    if (params.prompt.empty()) {
+        params.prompt =
+            "TurboQuant probe prompt. This prompt is intentionally long enough to exercise Q and K projections. "
+            "We want multiple semantically varied tokens about rockets, satellites, launch windows, orbital refueling, "
+            "AI agents, browsing, reasoning, and engineering tradeoffs so the probe captures realistic attention vectors.";
+    }
+
+    params.n_ctx = std::max(params.n_ctx, probe.probe_ctx);
+    params.n_batch = std::max(64, std::min(probe.probe_ctx, probe.max_prompt_tokens));
+    params.warmup = false;
+    params.cpuparams.n_threads = std::max(1, params.cpuparams.n_threads);
+    if (!probe.use_gpu) {
+        params.n_gpu_layers = 0;
+    }
+
+    return {params, probe};
+}
+
+static void run_probe(common_params & params, const probe_args & probe) {
+    probe_collector collector;
+    collector.q_name = string_format("Qcur-%d", probe.layer);
+    collector.k_name = string_format("Kcur-%d", probe.layer);
+    collector.max_vectors = probe.max_vectors;
+
+    params.cb_eval = turboquant_probe_eval;
+    params.cb_eval_user_data = &collector;
+
+    common_init();
+    llama_backend_init();
+    llama_numa_init(params.numa);
+
+    auto llama_init = common_init_from_params(params);
+    auto * ctx = llama_init->context();
+    auto * model = llama_init->model();
+    if (ctx == nullptr || model == nullptr) {
+        throw std::runtime_error("failed to initialize model/context");
+    }
+
+    const std::vector<llama_token> all_tokens = common_tokenize(ctx, params.prompt, true, params.parse_special);
+    if (all_tokens.size() < 8) {
+        throw std::runtime_error("prompt tokenization produced too few tokens for probing");
+    }
+    const int n_tokens = std::min<int>(probe.max_prompt_tokens, all_tokens.size());
+    std::vector<llama_token> tokens(all_tokens.begin(), all_tokens.begin() + n_tokens);
+
+    llama_memory_clear(llama_get_memory(ctx), true);
+    if (llama_decode(ctx, llama_batch_get_one(tokens.data(), tokens.size()))) {
+        throw std::runtime_error("llama_decode failed during TurboQuant probe");
+    }
+    llama_synchronize(ctx);
+
+    if (collector.q_capture.raw.empty() || collector.k_capture.raw.empty()) {
+        std::string seen;
+        for (size_t i = 0; i < collector.seen_names.size(); ++i) {
+            if (i) {
+                seen += ", ";
+            }
+            seen += collector.seen_names[i];
+        }
+        throw std::runtime_error(
+            string_format("did not capture required tensors (wanted %s and %s). seen names: %s",
+                collector.q_name.c_str(), collector.k_name.c_str(), seen.c_str()));
+    }
+
+    if (collector.q_capture.vectors.empty()) {
+        collector.q_capture.vectors = unpack_attention_vectors(collector.q_capture, collector.max_vectors);
+    }
+    if (collector.k_capture.vectors.empty()) {
+        const int expected_head_dim = collector.q_capture.vectors.empty() ? 0 : static_cast<int>(collector.q_capture.vectors.front().size());
+        collector.k_capture.vectors = unpack_attention_vectors(collector.k_capture, collector.max_vectors, expected_head_dim);
+    }
+
+    if (collector.q_capture.vectors.front().size() != collector.k_capture.vectors.front().size()) {
+        throw std::runtime_error(
+            string_format("captured Q/K dims differ: q=%zu k=%zu (q ne=[%lld,%lld,%lld,%lld] nb=[%zu,%zu,%zu,%zu] type=%s; k ne=[%lld,%lld,%lld,%lld] nb=[%zu,%zu,%zu,%zu] type=%s)",
+                collector.q_capture.vectors.front().size(),
+                collector.k_capture.vectors.front().size(),
+                (long long) collector.q_capture.ne[0], (long long) collector.q_capture.ne[1], (long long) collector.q_capture.ne[2], (long long) collector.q_capture.ne[3],
+                collector.q_capture.nb[0], collector.q_capture.nb[1], collector.q_capture.nb[2], collector.q_capture.nb[3], ggml_type_name(collector.q_capture.type),
+                (long long) collector.k_capture.ne[0], (long long) collector.k_capture.ne[1], (long long) collector.k_capture.ne[2], (long long) collector.k_capture.ne[3],
+                collector.k_capture.nb[0], collector.k_capture.nb[1], collector.k_capture.nb[2], collector.k_capture.nb[3], ggml_type_name(collector.k_capture.type)));
+    }
+
+    const int dim = static_cast<int>(collector.k_capture.vectors.front().size());
+
+    turboquant_init_params tq_params;
+    tq_params.dim = dim;
+    tq_params.bits = probe.bits;
+    tq_params.qjl_dim = probe.qjl_dim;
+    tq_params.seed = 42;
+
+    turboquant_init_params prod_mse_params = tq_params;
+    prod_mse_params.bits = std::max(1, probe.bits - 1);
+
+    turboquant_mse mse_quant(tq_params);
+    turboquant_mse prod_mse_quant(prod_mse_params);
+    turboquant_prod prod_quant(tq_params);
+
+    const auto mse_metrics = turboquant_score_mse(mse_quant, collector.k_capture.vectors);
+    const auto prod_reference_mse_metrics = turboquant_score_mse(prod_mse_quant, collector.k_capture.vectors);
+    const auto prod_reference_ip_metrics = turboquant_score_mse_inner_products(
+        prod_mse_quant, collector.k_capture.vectors, collector.q_capture.vectors);
+    const auto prod_metrics = turboquant_score_prod(
+        prod_quant, collector.k_capture.vectors, collector.q_capture.vectors);
+    std::vector<float> queries_flat;
+    std::vector<float> dataset_flat;
+    std::vector<float> prod_mse_flat;
+    std::vector<int8_t> prod_qjl_signs_flat;
+    std::vector<float> prod_residual_norms;
+    if (probe.use_cuda_exact) {
+        queries_flat = flatten_vectors(collector.q_capture.vectors, dim);
+        dataset_flat = flatten_vectors(collector.k_capture.vectors, dim);
+        prod_mse_flat.reserve(size_t(collector.k_capture.vectors.size()) * dim);
+        prod_qjl_signs_flat.reserve(size_t(collector.k_capture.vectors.size()) * (probe.qjl_dim > 0 ? probe.qjl_dim : dim));
+        prod_residual_norms.reserve(collector.k_capture.vectors.size());
+        for (const auto & key : collector.k_capture.vectors) {
+            const auto compressed = prod_quant.quantize(key);
+            const auto dequantized = prod_quant.dequantize(compressed);
+            prod_mse_flat.insert(prod_mse_flat.end(), dequantized.begin(), dequantized.end());
+            prod_qjl_signs_flat.insert(prod_qjl_signs_flat.end(), compressed.qjl_signs.begin(), compressed.qjl_signs.end());
+            prod_residual_norms.push_back(compressed.residual_norm);
+        }
+    }
+    turboquant_metrics prod_cuda_metrics = {};
+    std::string prod_cuda_error;
+    const bool have_prod_cuda = probe.use_cuda_exact && turboquant_score_prod_cuda_raw(
+        queries_flat,
+        dataset_flat,
+        prod_mse_flat,
+        prod_qjl_signs_flat,
+        prod_residual_norms,
+        prod_quant.qjl_matrix(),
+        static_cast<int>(collector.q_capture.vectors.size()),
+        static_cast<int>(collector.k_capture.vectors.size()),
+        dim,
+        prod_quant.qjl_dim(),
+        prod_cuda_metrics,
+        prod_cuda_error);
+
+    std::string json = string_format(
+        "{"
+        "\"model\":\"%s\","
+        "\"layer\":%d,"
+        "\"tensor_q\":\"%s\","
+        "\"tensor_k\":\"%s\","
+        "\"prompt_tokens\":%d,"
+        "\"vector_dim\":%d,"
+        "\"captured_queries\":%zu,"
+        "\"captured_keys\":%zu,"
+        "\"bits\":%d,"
+        "\"prod_mse_bits\":%d,"
+        "\"qjl_dim\":%d,"
+        "\"mse_stage\":%s,"
+        "\"prod_reference_mse_stage\":%s,"
+        "\"prod_reference_ip_stage\":%s,"
+        "\"prod_stage\":%s",
+        params.model.path.c_str(),
+        probe.layer,
+        collector.q_capture.name.c_str(),
+        collector.k_capture.name.c_str(),
+        n_tokens,
+        dim,
+        collector.q_capture.vectors.size(),
+        collector.k_capture.vectors.size(),
+        probe.bits,
+        std::max(1, probe.bits - 1),
+        probe.qjl_dim > 0 ? probe.qjl_dim : dim,
+        turboquant_metrics_json(mse_metrics).c_str(),
+        turboquant_metrics_json(prod_reference_mse_metrics).c_str(),
+        turboquant_metrics_json(prod_reference_ip_metrics).c_str(),
+        turboquant_metrics_json(prod_metrics).c_str());
+
+    if (have_prod_cuda) {
+        json += string_format(
+            ",\"prod_cuda_stage\":%s",
+            turboquant_metrics_json(prod_cuda_metrics).c_str());
+    } else if (!prod_cuda_error.empty()) {
+        std::string escaped = prod_cuda_error;
+        size_t pos = 0;
+        while ((pos = escaped.find('"', pos)) != std::string::npos) {
+            escaped.replace(pos, 1, "\\\"");
+            pos += 2;
+        }
+        json += string_format(",\"prod_cuda_error\":\"%s\"", escaped.c_str());
+    }
+    json += "}\n";
+    std::printf("%s", json.c_str());
+
+    llama_backend_free();
+}
+
+} // namespace
+
+int main(int argc, char ** argv) {
+    try {
+        auto [params, probe] = parse_args(argc, argv);
+        run_probe(params, probe);
+        return 0;
+    } catch (const std::exception & exc) {
+        std::fprintf(stderr, "llama-turboquant-probe: %s\n", exc.what());
+        return 1;
+    }
+}
diff --git a/tools/turboquant-probe/turboquant-probe-cuda.h b/tools/turboquant-probe/turboquant-probe-cuda.h
new file mode 100644
index 0000000..841a63c
--- /dev/null
+++ b/tools/turboquant-probe/turboquant-probe-cuda.h
@@ -0,0 +1,25 @@
+#pragma once
+
+#include "../../common/turboquant.h"
+
+#include <cstdint>
+#include <string>
+#include <vector>
+
+namespace llama_lab {
+
+bool turboquant_score_prod_cuda_raw(
+        const std::vector<float> & queries_flat,
+        const std::vector<float> & dataset_flat,
+        const std::vector<float> & mse_flat,
+        const std::vector<int8_t> & qjl_signs_flat,
+        const std::vector<float> & residual_norms,
+        const std::vector<float> & qjl_matrix,
+        int nq,
+        int nk,
+        int dim,
+        int qjl_dim,
+        turboquant_metrics & metrics_out,
+        std::string & error_out);
+
+} // namespace llama_lab
