+static int align_up_int(int value, int alignment) {
+    return ((value + alignment - 1) / alignment) * alignment;
+}
+
+static int turboquant_index_bytes_for_bits(int dim, int bits) {
+    return (dim * bits + 7) / 8;
+}
+
+__device__ __forceinline__ uint8_t turboquant_load_code_device(const uint8_t * src, int idx, int bits) {
+    const int bit_offset = idx * bits;
+    const int byte_offset = bit_offset / 8;
+    const int shift = bit_offset % 8;
+    uint16_t word = src[byte_offset];
+    if (shift + bits > 8) {
+        word |= uint16_t(src[byte_offset + 1]) << 8;
+    }
+    return uint8_t((word >> shift) & ((1u << bits) - 1u));
+}
