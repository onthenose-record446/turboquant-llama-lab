+static std::shared_ptr<turboquant_exact_device_params> get_turboquant_exact_device_params(int dim, int bits, int qjl_dim, int outlier_channels) {
+    static std::mutex mutex;
+    static std::unordered_map<std::string, std::shared_ptr<turboquant_exact_device_params>> cache;
+
+    const std::string key = std::to_string(dim) + ":" + std::to_string(bits) + ":" + std::to_string(qjl_dim) + ":" + std::to_string(outlier_channels);
+    std::lock_guard<std::mutex> lock(mutex);
+    auto it = cache.find(key);
+    if (it != cache.end()) {
+        return it->second;
+    }
+
+    auto params = std::make_shared<turboquant_exact_device_params>();
+    params->dim = dim;
+    params->bits = bits;
+    params->mse_bits = std::max(1, bits - 1);
+    params->qjl_dim = qjl_dim;
+    params->outlier_channels = std::max(0, outlier_channels);
+    params->n_levels = 1 << params->mse_bits;
+    params->layout = make_turboquant_packed_layout(dim, params->mse_bits, qjl_dim, params->outlier_channels);
+    params->correction_scale = std::sqrt(float(kPi / 2.0)) / float(qjl_dim);
+    params->rotation = build_rotation_matrix(dim, 42);
+    params->centroids = solve_lloyd_max_centroids(dim, params->mse_bits, 96, 4096);
+    params->boundaries = make_boundaries(params->centroids);
+    params->qjl_matrix = build_gaussian_matrix(qjl_dim, dim, 43);
+
+    cuda_check(cudaMalloc(&params->d_rotation.ptr, params->rotation.size() * sizeof(float)), "cudaMalloc turboquant rotation");
+    cuda_check(cudaMalloc(&params->d_boundaries.ptr, params->boundaries.size() * sizeof(float)), "cudaMalloc turboquant boundaries");
+    cuda_check(cudaMalloc(&params->d_centroids.ptr, params->centroids.size() * sizeof(float)), "cudaMalloc turboquant centroids");
+    cuda_check(cudaMalloc(&params->d_qjl_matrix.ptr, params->qjl_matrix.size() * sizeof(float)), "cudaMalloc turboquant qjl");
+
+    cuda_check(cudaMemcpy(params->d_rotation.ptr, params->rotation.data(), params->rotation.size() * sizeof(float), cudaMemcpyHostToDevice), "cudaMemcpy turboquant rotation");
+    cuda_check(cudaMemcpy(params->d_boundaries.ptr, params->boundaries.data(), params->boundaries.size() * sizeof(float), cudaMemcpyHostToDevice), "cudaMemcpy turboquant boundaries");
+    cuda_check(cudaMemcpy(params->d_centroids.ptr, params->centroids.data(), params->centroids.size() * sizeof(float), cudaMemcpyHostToDevice), "cudaMemcpy turboquant centroids");
+    cuda_check(cudaMemcpy(params->d_qjl_matrix.ptr, params->qjl_matrix.data(), params->qjl_matrix.size() * sizeof(float), cudaMemcpyHostToDevice), "cudaMemcpy turboquant qjl");
+
+    cache.emplace(key, params);
+    return params;
+}
+
+static std::shared_ptr<turboquant_exact_key_cache_entry> get_turboquant_exact_key_cache(
+        const turboquant_exact_cache_key & key,
+        int required_rows,
+        int packed_row_bytes) {
+    static std::mutex mutex;
+    static std::unordered_map<turboquant_exact_cache_key, std::shared_ptr<turboquant_exact_key_cache_entry>, turboquant_exact_cache_key_hash> cache;
+
+    std::lock_guard<std::mutex> lock(mutex);
+    auto it = cache.find(key);
+    if (it == cache.end()) {
+        auto entry = std::make_shared<turboquant_exact_key_cache_entry>();
+        cache.emplace(key, entry);
+        it = cache.find(key);
+    }
+
+    auto entry = it->second;
+    if (entry->capacity_rows >= required_rows) {
+        return entry;
+    }
+
+    const int new_capacity = std::max(required_rows, std::max(256, entry->capacity_rows * 2));
+    entry->d_packed.reset();
+    entry->packed_row_bytes = packed_row_bytes;
+    cuda_check(cudaMalloc(&entry->d_packed.ptr, size_t(new_capacity) * packed_row_bytes), "cudaMalloc turboquant cache packed rows");
+    entry->capacity_rows = new_capacity;
+    entry->compressed_rows = 0;
+    entry->last_rows_seen = -1;
+    return entry;
+}
+
+__global__ void turboquant_project_queries_kernel(
+        const float * __restrict__ queries,
+        const float * __restrict__ qjl_matrix,
+        float * __restrict__ projected,
+        int nq,
+        int qjl_dim,
+        int dim) {
+    const int idx = blockIdx.x * blockDim.x + threadIdx.x;
+    const int total = nq * qjl_dim;
+    if (idx >= total) {
+        return;
+    }
+
+    const int q_idx = idx / qjl_dim;
+    const int row = idx - q_idx * qjl_dim;
+
+    const float * q = queries + q_idx * dim;
+    const float * a = qjl_matrix + row * dim;
+
+    float acc = 0.0f;
+    for (int i = 0; i < dim; ++i) {
+        acc += q[i] * a[i];
+    }
+    projected[idx] = acc;
+}
+
+__global__ void turboquant_score_kernel(
+        const float * __restrict__ queries,
+        const float * __restrict__ dataset,
+        const float * __restrict__ projected_queries,
+        const float * __restrict__ mse_vecs,
+        const int8_t * __restrict__ qjl_signs,
+        const float * __restrict__ residual_norms,
+        float * __restrict__ out_truth,
+        float * __restrict__ out_scores,
+        int nq,
+        int nk,
+        int dim,
+        int qjl_dim,
+        float correction_scale) {
+    const int idx = blockIdx.x * blockDim.x + threadIdx.x;
+    const int total = nq * nk;
+    if (idx >= total) {
+        return;
+    }
+
+    const int q_idx = idx / nk;
+    const int k_idx = idx - q_idx * nk;
+
+    const float * q = queries + q_idx * dim;
+    const float * x = dataset + k_idx * dim;
+    const float * mse = mse_vecs + k_idx * dim;
+    const float * proj_q = projected_queries + q_idx * qjl_dim;
+    const int8_t * signs = qjl_signs + k_idx * qjl_dim;
+
+    float truth = 0.0f;
+    float term1 = 0.0f;
+    for (int i = 0; i < dim; ++i) {
+        const float qv = q[i];
+        truth += qv * x[i];
+        term1 += qv * mse[i];
+    }
+
+    float qjl_ip = 0.0f;
+    for (int i = 0; i < qjl_dim; ++i) {
+        qjl_ip += proj_q[i] * float(signs[i]);
+    }
+
+    out_truth[idx] = truth;
+    out_scores[idx] = term1 + residual_norms[k_idx] * correction_scale * qjl_ip;
+}
+
+__global__ void turboquant_compress_keys_kernel(
+        const float * __restrict__ keys,
+        float * __restrict__ mse_out,
+        int8_t * __restrict__ signs_out,
+        float * __restrict__ residual_norm_out,
+        const float * __restrict__ rotation,
+        const float * __restrict__ boundaries,
+        const float * __restrict__ centroids,
+        const float * __restrict__ qjl_matrix,
+        int dim,
+        int qjl_dim,
+        int nkv,
+        int row_offset,
+        int n_levels) {
+    const int local_row = blockIdx.x;
+    const int row = row_offset + local_row;
+    const int tid = threadIdx.x;
+    if (row >= nkv) {
+        return;
+    }
+
+    extern __shared__ float shmem[];
+    float * x = shmem;
+    float * rotated = x + dim;
+    float * x_mse = rotated + dim;
+    float * residual = x_mse + dim;
+    float * reduce = residual + dim;
+
+    const float * key = keys + size_t(row) * dim;
+    if (tid < dim) {
+        x[tid] = key[tid];
+    }
+    __syncthreads();
+
+    float part = 0.0f;
+    for (int i = tid; i < dim; i += blockDim.x) {
+        part += x[i] * x[i];
+    }
+    reduce[tid] = part;
+    __syncthreads();
+    for (int stride = blockDim.x / 2; stride > 0; stride >>= 1) {
+        if (tid < stride) {
+            reduce[tid] += reduce[tid + stride];
+        }
+        __syncthreads();
+    }
+    const float norm = reduce[0] > 0.0f ? sqrtf(reduce[0]) : 1.0f;
+
+    for (int r = tid; r < dim; r += blockDim.x) {
+        float acc = 0.0f;
+        const float * rot_row = rotation + r * dim;
+        for (int c = 0; c < dim; ++c) {
+            acc += rot_row[c] * (x[c] / norm);
+        }
+        int idx = 0;
+        while (idx < n_levels - 1 && acc > boundaries[idx]) {
+            ++idx;
+        }
+        rotated[r] = centroids[idx];
+    }
+    __syncthreads();
+
+    for (int c = tid; c < dim; c += blockDim.x) {
+        float acc = 0.0f;
+        for (int r = 0; r < dim; ++r) {
+            acc += rotation[r * dim + c] * rotated[r];
+        }
+        const float val = acc * norm;
+        x_mse[c] = val;
+        residual[c] = x[c] - val;
+        mse_out[row * dim + c] = val;
+    }
+    __syncthreads();
+
+    part = 0.0f;
+    for (int i = tid; i < dim; i += blockDim.x) {
+        part += residual[i] * residual[i];
+    }
+    reduce[tid] = part;
+    __syncthreads();
+    for (int stride = blockDim.x / 2; stride > 0; stride >>= 1) {
+        if (tid < stride) {
+            reduce[tid] += reduce[tid + stride];
+        }
+        __syncthreads();
+    }
+    const float residual_norm = sqrtf(fmaxf(reduce[0], 0.0f));
+    if (tid == 0) {
+        residual_norm_out[row] = residual_norm;
+    }
+
+    for (int j = tid; j < qjl_dim; j += blockDim.x) {
+        float acc = 0.0f;
+        const float * a = qjl_matrix + j * dim;
+        for (int c = 0; c < dim; ++c) {
+            acc += a[c] * residual[c];
+        }
+        signs_out[row * qjl_dim + j] = acc >= 0.0f ? int8_t(1) : int8_t(-1);
+    }
+}
+
+__global__ void turboquant_project_qrows_kernel(
+        const float * __restrict__ queries,
+        float * __restrict__ projected,
+        const float * __restrict__ qjl_matrix,
+        int dim,
+        int qjl_dim,
+        int n_q,
+        int n_head_q,
+        int n_stream,
+        int64_t q_nb1,
+        int64_t q_nb2,
+        int64_t q_nb3) {
+    const int total = n_q * n_head_q * n_stream * qjl_dim;
+    const int idx = blockIdx.x * blockDim.x + threadIdx.x;
+    if (idx >= total) {
+        return;
+    }
+
+    const int qjl_row = idx % qjl_dim;
+    const int qrow = idx / qjl_dim;
+    const int q_tok = qrow % n_q;
+    const int q_head_stream = qrow / n_q;
+    const int q_head = q_head_stream % n_head_q;
+    const int stream = q_head_stream / n_head_q;
+
+    const char * q_ptr = reinterpret_cast<const char *>(queries)
+            + q_tok * q_nb1
+            + q_head * q_nb2
+            + stream * q_nb3;
+    const float * q = reinterpret_cast<const float *>(q_ptr);
+    const float * a = qjl_matrix + qjl_row * dim;
+
+    float acc = 0.0f;
+    for (int i = 0; i < dim; ++i) {
+        acc += q[i] * a[i];
+    }
+    projected[idx] = acc;
+}
+
+__global__ void turboquant_kq_kernel(
+        const float * __restrict__ queries,
+        const float * __restrict__ mse_keys,
+        const int8_t * __restrict__ qjl_signs,
+        const float * __restrict__ residual_norms,
+        const float * __restrict__ projected_queries,
+        float * __restrict__ dst,
+        int dim,
+        int qjl_dim,
+        int n_q,
+        int n_k,
+        int n_head_q,
+        int n_head_k,
+        int n_stream,
+        int64_t q_nb1,
+        int64_t q_nb2,
+        int64_t q_nb3,
+        int64_t dst_nb1,
+        int64_t dst_nb2,
+        int64_t dst_nb3,
+        float correction_scale) {
+    const int qrow = blockIdx.x;
+    const int kv_tok = blockIdx.y * blockDim.x + threadIdx.x;
+    if (qrow >= n_q * n_head_q * n_stream || kv_tok >= n_k) {
+        return;
+    }
+
+    const int q_tok = qrow % n_q;
+    const int q_head_stream = qrow / n_q;
+    const int q_head = q_head_stream % n_head_q;
+    const int stream = q_head_stream / n_head_q;
+    const int kv_head = (q_head * n_head_k) / n_head_q;
+
+    const char * q_ptr = reinterpret_cast<const char *>(queries)
+            + q_tok * q_nb1
+            + q_head * q_nb2
+            + stream * q_nb3;
+    const float * q = reinterpret_cast<const float *>(q_ptr);
+
+    const int key_row = stream * (n_head_k * n_k) + kv_head * n_k + kv_tok;
+    const float * mse = mse_keys + key_row * dim;
+    const int8_t * signs = qjl_signs + key_row * qjl_dim;
+    const float * proj_q = projected_queries + qrow * qjl_dim;
+
+    float term1 = 0.0f;
+    for (int i = 0; i < dim; ++i) {
+        term1 += q[i] * mse[i];
+    }
+
+    float qjl_ip = 0.0f;
+    for (int i = 0; i < qjl_dim; ++i) {
+        qjl_ip += proj_q[i] * float(signs[i]);
+    }
+
+    const float score = term1 + residual_norms[key_row] * correction_scale * qjl_ip;
+    char * out_ptr = reinterpret_cast<char *>(dst)
+            + kv_tok * sizeof(float)
+            + q_tok * dst_nb1
+            + q_head * dst_nb2
+            + stream * dst_nb3;
+    *reinterpret_cast<float *>(out_ptr) = score;
+}
+
+__global__ void turboquant_rotate_project_qrows_kernel(
+        const float * __restrict__ queries,
+        float * __restrict__ rotated_queries,
+        float * __restrict__ projected_queries,
+        const float * __restrict__ rotation,
+        const float * __restrict__ qjl_matrix,
+        int dim,
+        int qjl_dim,
+        int n_q,
+        int n_head_q,
+        int n_stream,
+        int64_t q_nb1,
+        int64_t q_nb2,
+        int64_t q_nb3) {
+    const int qrow = blockIdx.x;
+    const int tid = threadIdx.x;
+    const int qrow_total = n_q * n_head_q * n_stream;
+    if (qrow >= qrow_total) {
+        return;
+    }
+
+    const int q_tok = qrow % n_q;
+    const int q_head_stream = qrow / n_q;
+    const int q_head = q_head_stream % n_head_q;
+    const int stream = q_head_stream / n_head_q;
+
+    const char * q_ptr = reinterpret_cast<const char *>(queries)
+            + q_tok * q_nb1
+            + q_head * q_nb2
+            + stream * q_nb3;
+    const float * q = reinterpret_cast<const float *>(q_ptr);
+    extern __shared__ float sh_q[];
+    for (int i = tid; i < dim; i += blockDim.x) {
+        sh_q[i] = q[i];
+    }
+    __syncthreads();
+
+    for (int r = tid; r < dim; r += blockDim.x) {
+        float acc = 0.0f;
+        const float * rot_row = rotation + r * dim;
+        for (int c = 0; c < dim; ++c) {
+            acc += rot_row[c] * sh_q[c];
+        }
+        rotated_queries[qrow * dim + r] = acc;
+    }
+
+    for (int j = tid; j < qjl_dim; j += blockDim.x) {
+        float acc = 0.0f;
+        const float * a = qjl_matrix + j * dim;
+        for (int c = 0; c < dim; ++c) {
+            acc += a[c] * sh_q[c];
+        }
+        projected_queries[qrow * qjl_dim + j] = acc;
+    }
+}
+
+__global__ void turboquant_compress_keys_compact_kernel(
+        const float * __restrict__ keys,
+        int8_t * __restrict__ packed_out,
+        const float * __restrict__ rotation,
+        const float * __restrict__ boundaries,
+        const float * __restrict__ centroids,
+        const float * __restrict__ qjl_matrix,
+        int dim,
+        int mse_bits,
+        int qjl_dim,
+        int outlier_channels,
+        int n_sign_words,
+        int packed_row_bytes,
+        int vec_norm_offset,
+        int residual_norm_offset,
+        int sign_words_offset,
+        int outlier_indices_offset,
+        int outlier_values_offset,
+        int nkv,
+        int row_offset,
+        int n_levels,
+        int n_k,
+        int n_head_k,
+        int n_stream,
+        int64_t k_nb1,
+        int64_t k_nb2,
+        int64_t k_nb3,
+        int64_t packed_nb1,
+        int64_t packed_nb2,
+        int64_t packed_nb3) {
+    const int local_row = blockIdx.x;
+    const int row = row_offset + local_row;
+    const int tid = threadIdx.x;
+    if (row >= nkv) {
+        return;
+    }
+
+    const int kv_tok = row % n_k;
+    const int kv_head_stream = row / n_k;
+    const int kv_head = kv_head_stream % n_head_k;
+    const int stream = kv_head_stream / n_head_k;
+
+    const char * key_ptr = reinterpret_cast<const char *>(keys)
+            + kv_tok * k_nb1
+            + kv_head * k_nb2
+            + stream * k_nb3;
+    const float * key = reinterpret_cast<const float *>(key_ptr);
+    int8_t * packed_row = packed_out
+            + kv_tok * packed_nb1
+            + kv_head * packed_nb2
+            + stream * packed_nb3;
+    uint8_t * code_bytes = reinterpret_cast<uint8_t *>(packed_row);
+    float * vec_norm_out = reinterpret_cast<float *>(packed_row + vec_norm_offset);
+    float * residual_norm_out = reinterpret_cast<float *>(packed_row + residual_norm_offset);
+    uint32_t * sign_words_out = reinterpret_cast<uint32_t *>(packed_row + sign_words_offset);
+    uint16_t * outlier_idx_out = outlier_channels > 0 ? reinterpret_cast<uint16_t *>(packed_row + outlier_indices_offset) : nullptr;
+    float * outlier_val_out = outlier_channels > 0 ? reinterpret_cast<float *>(packed_row + outlier_values_offset) : nullptr;
+
+    extern __shared__ float shmem_compact[];
+    float * key_sh = shmem_compact;
+    float * rotated = key_sh + dim;
+    float * residual = rotated + dim;
+    uint16_t * compact_codes = reinterpret_cast<uint16_t *>(residual + dim);
+
+    for (int i = tid; i < dim; i += blockDim.x) {
+        key_sh[i] = key[i];
+    }
+    __syncthreads();
+
+    float norm_sq = 0.0f;
+    for (int i = tid; i < dim; i += blockDim.x) {
+        norm_sq += key_sh[i] * key_sh[i];
+    }
+    norm_sq = block_reduce_sum(norm_sq);
+    const float norm = norm_sq > 0.0f ? sqrtf(norm_sq) : 1.0f;
+    const float inv_norm = 1.0f / norm;
+    if (tid == 0) {
+        *vec_norm_out = norm;
+    }
+
+    for (int r = tid; r < dim; r += blockDim.x) {
+        float acc = 0.0f;
+        const float * rot_row = rotation + r * dim;
+        for (int c = 0; c < dim; ++c) {
+            acc += rot_row[c] * (key_sh[c] * inv_norm);
+        }
+        int idx = 0;
+        while (idx < n_levels - 1 && acc > boundaries[idx]) {
+            ++idx;
+        }
+        compact_codes[r] = static_cast<uint16_t>(idx);
+        rotated[r] = centroids[idx];
+    }
+    __syncthreads();
+
+    for (int byte_idx = tid; byte_idx < vec_norm_offset; byte_idx += blockDim.x) {
+        uint32_t packed = 0;
+        const int first_idx = (byte_idx * 8) / mse_bits;
+        const int last_idx = min(dim - 1, (((byte_idx + 1) * 8) - 1) / mse_bits);
+        for (int idx = first_idx; idx <= last_idx; ++idx) {
+            const int local_bit = idx * mse_bits - byte_idx * 8;
+            const uint32_t code = compact_codes[idx] & ((1u << mse_bits) - 1u);
+            if (local_bit >= 0) {
+                packed |= code << local_bit;
+            } else {
+                packed |= code >> (-local_bit);
+            }
+        }
+        code_bytes[byte_idx] = uint8_t(packed & 0xFFu);
+    }
+    __syncthreads();
+
+    for (int c = tid; c < dim; c += blockDim.x) {
+        float acc = 0.0f;
+        for (int r = 0; r < dim; ++r) {
+            acc += rotation[r * dim + c] * rotated[r];
+        }
+        residual[c] = key_sh[c] - acc * norm;
+    }
+    __syncthreads();
+
+    if (outlier_channels > 0 && tid == 0) {
+        for (int oi = 0; oi < outlier_channels; ++oi) {
+            int best_idx = 0;
+            float best_abs = -1.0f;
+            for (int c = 0; c < dim; ++c) {
+                const float absv = fabsf(residual[c]);
+                if (absv > best_abs) {
+                    best_abs = absv;
+                    best_idx = c;
+                }
+            }
+            outlier_idx_out[oi] = static_cast<uint16_t>(best_idx);
+            outlier_val_out[oi] = residual[best_idx];
+            residual[best_idx] = 0.0f;
+        }
+    }
+    __syncthreads();
+
+    float residual_sq = 0.0f;
+    for (int c = tid; c < dim; c += blockDim.x) {
+        residual_sq += residual[c] * residual[c];
+    }
+    residual_sq = block_reduce_sum(residual_sq);
+    if (tid == 0) {
+        *residual_norm_out = sqrtf(fmaxf(residual_sq, 0.0f));
+    }
+
+    for (int w = tid; w < n_sign_words; w += blockDim.x) {
+        uint32_t bits = 0;
+        for (int b = 0; b < 32; ++b) {
+            const int j = w * 32 + b;
+            if (j >= qjl_dim) {
+                break;
+            }
+            float acc = 0.0f;
+            const float * a = qjl_matrix + j * dim;
+            for (int c = 0; c < dim; ++c) {
+                acc += a[c] * residual[c];
+            }
+            if (acc >= 0.0f) {
+                bits |= (1u << b);
+            }
+        }
+        sign_words_out[w] = bits;
+    }
+}
+
+__global__ void turboquant_kq_compact_kernel(
+        const float * __restrict__ queries,
+        const float * __restrict__ rotated_queries,
+        const float * __restrict__ projected_queries,
+        const int8_t * __restrict__ packed_keys,
+        const float * __restrict__ centroids,
+        float * __restrict__ dst,
+        int dim,
+        int mse_bits,
+        int qjl_dim,
+        int outlier_channels,
+        int n_sign_words,
+        int packed_row_bytes,
+        int vec_norm_offset,
+        int residual_norm_offset,
+        int sign_words_offset,
+        int outlier_indices_offset,
+        int outlier_values_offset,
+        int n_q,
+        int n_k,
+        int n_head_q,
+        int n_head_k,
+        int n_stream,
+        int64_t q_nb1,
+        int64_t q_nb2,
+        int64_t q_nb3,
+        int64_t k_nb1,
+        int64_t k_nb2,
+        int64_t k_nb3,
+        int64_t dst_nb1,
+        int64_t dst_nb2,
+        int64_t dst_nb3,
+        float correction_scale) {
+    const int qrow = blockIdx.x;
+    const int lane = threadIdx.x & 31;
+    const int warp = threadIdx.x >> 5;
+    const int warps_per_block = blockDim.x >> 5;
+    const int kv_tok = blockIdx.y * warps_per_block + warp;
+    if (qrow >= n_q * n_head_q * n_stream || kv_tok >= n_k) {
+        return;
+    }
+
+    const int q_tok = qrow % n_q;
+    const int q_head_stream = qrow / n_q;
+    const int q_head = q_head_stream % n_head_q;
+    const int stream = q_head_stream / n_head_q;
+    const int kv_head = (q_head * n_head_k) / n_head_q;
+    const int key_row = stream * (n_head_k * n_k) + kv_head * n_k + kv_tok;
+
+    const char * q_ptr = reinterpret_cast<const char *>(queries)
+            + q_tok * q_nb1
+            + q_head * q_nb2
+            + stream * q_nb3;
+    const float * q = reinterpret_cast<const float *>(q_ptr);
+    const float * rot_q = rotated_queries + qrow * dim;
+    const float * proj_q = projected_queries + qrow * qjl_dim;
+    float proj_q_total = 0.0f;
+    for (int j = lane; j < qjl_dim; j += 32) {
+        proj_q_total += proj_q[j];
+    }
+    proj_q_total = warp_reduce_sum(proj_q_total);
+
+    const int8_t * packed_row = packed_keys
+            + kv_tok * k_nb1
+            + kv_head * k_nb2
+            + stream * k_nb3;
+    const uint8_t * idxs = reinterpret_cast<const uint8_t *>(packed_row);
+    const float vec_norm = *reinterpret_cast<const float *>(packed_row + vec_norm_offset);
+    const float residual_norm = *reinterpret_cast<const float *>(packed_row + residual_norm_offset);
+    const uint32_t * words = reinterpret_cast<const uint32_t *>(packed_row + sign_words_offset);
+    const uint16_t * outlier_indices = outlier_channels > 0 ? reinterpret_cast<const uint16_t *>(packed_row + outlier_indices_offset) : nullptr;
+    const float * outlier_values = outlier_channels > 0 ? reinterpret_cast<const float *>(packed_row + outlier_values_offset) : nullptr;
+
+    float term1 = 0.0f;
+    for (int i = lane; i < dim; i += 32) {
+        term1 += rot_q[i] * centroids[turboquant_load_code_device(idxs, i, mse_bits)];
+    }
+    term1 = warp_reduce_sum(term1) * vec_norm;
+
+    float outlier_term = 0.0f;
+    for (int oi = lane; oi < outlier_channels; oi += 32) {
+        const uint16_t idx = outlier_indices[oi];
+        outlier_term += q[idx] * outlier_values[oi];
+    }
+    outlier_term = warp_reduce_sum(outlier_term);
+
+    float qjl_ip = -proj_q_total;
+    for (int w = lane; w < n_sign_words; w += 32) {
+        const uint32_t bits = words[w];
+        const int base = w * 32;
+        for (int b = 0; b < 32; ++b) {
+            const int j = base + b;
+            if (j >= qjl_dim) {
+                break;
+            }
+            if (bits & (1u << b)) {
+                qjl_ip += 2.0f * proj_q[j];
+            }
+        }
+    }
+    qjl_ip = warp_reduce_sum(qjl_ip);
+
+    if (lane == 0) {
+        const float score = term1 + outlier_term + residual_norm * correction_scale * qjl_ip;
+        char * out_ptr = reinterpret_cast<char *>(dst)
+                + kv_tok * sizeof(float)
+                + q_tok * dst_nb1
+                + q_head * dst_nb2
+                + stream * dst_nb3;
+        *reinterpret_cast<float *>(out_ptr) = score;
+    }
+}
