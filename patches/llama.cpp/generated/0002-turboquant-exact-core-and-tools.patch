+__device__ inline float warp_reduce_sum(float value) {
+    for (int offset = 16; offset > 0; offset >>= 1) {
+        value += __shfl_down_sync(0xffffffff, value, offset);
+    }
+    return value;
+}
+
+__device__ inline float block_reduce_sum(float value) {
+    __shared__ float warp_sums[8];
+
+    const int lane = threadIdx.x & 31;
+    const int warp = threadIdx.x >> 5;
+    const int nwarps = (blockDim.x + 31) >> 5;
+
+    value = warp_reduce_sum(value);
+    if (lane == 0) {
+        warp_sums[warp] = value;
+    }
+    __syncthreads();
+
+    float block_sum = 0.0f;
+    if (warp == 0) {
+        block_sum = lane < nwarps ? warp_sums[lane] : 0.0f;
+        block_sum = warp_reduce_sum(block_sum);
+        if (lane == 0) {
+            warp_sums[0] = block_sum;
+        }
+    }
+    __syncthreads();
+
+    return warp_sums[0];
+}
+
+__device__ __forceinline__ float turboquant_load_v_value(const char * v_base, ggml_type v_type, int dim_idx) {
+    if (v_type == GGML_TYPE_F16) {
+        const char * v_ptr = v_base + dim_idx * int64_t(sizeof(half));
+        return __half2float(*reinterpret_cast<const half *>(v_ptr));
+    }
+    if (v_type == GGML_TYPE_Q8_0) {
+        const block_q8_0 * v_blocks = reinterpret_cast<const block_q8_0 *>(v_base);
+        const int block_idx = dim_idx / QK8_0;
+        const int block_off = dim_idx % QK8_0;
+        return float(v_blocks[block_idx].qs[block_off]) * float(v_blocks[block_idx].d);
+    }
+    if (v_type == GGML_TYPE_Q4_0) {
+        float2 dq;
+        dequantize_q4_0(v_base, dim_idx / QK4_0, dim_idx % (QK4_0 / 2), dq);
+        return (dim_idx % QK4_0) < (QK4_0 / 2) ? dq.x : dq.y;
+    }
+    if (v_type == GGML_TYPE_Q4_1) {
+        float2 dq;
+        dequantize_q4_1(v_base, dim_idx / QK4_1, dim_idx % (QK4_1 / 2), dq);
+        return (dim_idx % QK4_1) < (QK4_1 / 2) ? dq.x : dq.y;
+    }
+    if (v_type == GGML_TYPE_Q5_0) {
+        float2 dq;
+        dequantize_q5_0(v_base, dim_idx / QK5_0, dim_idx % (QK5_0 / 2), dq);
+        return (dim_idx % QK5_0) < (QK5_0 / 2) ? dq.x : dq.y;
+    }
+    if (v_type == GGML_TYPE_Q5_1) {
+        float2 dq;
+        dequantize_q5_1(v_base, dim_idx / QK5_1, dim_idx % (QK5_1 / 2), dq);
+        return (dim_idx % QK5_1) < (QK5_1 / 2) ? dq.x : dq.y;
+    }
+    return 0.0f;
+}
