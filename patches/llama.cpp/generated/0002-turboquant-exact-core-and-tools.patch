+bool turboquant_score_prod_cuda_raw(
+        const std::vector<float> & queries_flat,
+        const std::vector<float> & dataset_flat,
+        const std::vector<float> & mse_flat,
+        const std::vector<int8_t> & qjl_signs_flat,
+        const std::vector<float> & residual_norms,
+        const std::vector<float> & qjl_matrix,
+        int nq,
+        int nk,
+        int dim,
+        int qjl_dim,
+        turboquant_metrics & metrics_out,
+        std::string & error_out) {
+    metrics_out = {};
+    error_out.clear();
+
+    try {
+        if (nq <= 0 || nk <= 0 || dim <= 0 || qjl_dim <= 0) {
+            error_out = "invalid TurboQuant CUDA dimensions";
+            return false;
+        }
+
+        if ((int) queries_flat.size() != nq * dim ||
+            (int) dataset_flat.size() != nk * dim ||
+            (int) mse_flat.size() != nk * dim ||
+            (int) qjl_signs_flat.size() != nk * qjl_dim ||
+            (int) residual_norms.size() != nk ||
+            (int) qjl_matrix.size() != qjl_dim * dim) {
+            error_out = "TurboQuant CUDA scorer input size mismatch";
+            return false;
+        }
+
+        const int pair_count = nq * nk;
+        const float correction_scale = std::sqrt(3.14159265358979323846f / 2.0f) / float(qjl_dim);
+
+        cuda_buffer d_queries;
+        cuda_buffer d_dataset;
+        cuda_buffer d_projected;
+        cuda_buffer d_mse;
+        cuda_buffer d_signs;
+        cuda_buffer d_residual_norms;
+        cuda_buffer d_qjl_matrix;
+        cuda_buffer d_truth;
+        cuda_buffer d_scores;
+
+        cuda_check(cudaMalloc(&d_queries.ptr, queries_flat.size() * sizeof(float)), "cudaMalloc queries");
+        cuda_check(cudaMalloc(&d_dataset.ptr, dataset_flat.size() * sizeof(float)), "cudaMalloc dataset");
+        cuda_check(cudaMalloc(&d_projected.ptr, size_t(nq) * qjl_dim * sizeof(float)), "cudaMalloc projected queries");
+        cuda_check(cudaMalloc(&d_mse.ptr, mse_flat.size() * sizeof(float)), "cudaMalloc mse vectors");
+        cuda_check(cudaMalloc(&d_signs.ptr, qjl_signs_flat.size() * sizeof(int8_t)), "cudaMalloc qjl signs");
+        cuda_check(cudaMalloc(&d_residual_norms.ptr, residual_norms.size() * sizeof(float)), "cudaMalloc residual norms");
+        cuda_check(cudaMalloc(&d_qjl_matrix.ptr, qjl_matrix.size() * sizeof(float)), "cudaMalloc qjl matrix");
+        cuda_check(cudaMalloc(&d_truth.ptr, size_t(pair_count) * sizeof(float)), "cudaMalloc truth");
+        cuda_check(cudaMalloc(&d_scores.ptr, size_t(pair_count) * sizeof(float)), "cudaMalloc scores");
+
+        cuda_check(cudaMemcpy(d_queries.ptr, queries_flat.data(), queries_flat.size() * sizeof(float), cudaMemcpyHostToDevice), "cudaMemcpy queries");
+        cuda_check(cudaMemcpy(d_dataset.ptr, dataset_flat.data(), dataset_flat.size() * sizeof(float), cudaMemcpyHostToDevice), "cudaMemcpy dataset");
+        cuda_check(cudaMemcpy(d_mse.ptr, mse_flat.data(), mse_flat.size() * sizeof(float), cudaMemcpyHostToDevice), "cudaMemcpy mse vectors");
+        cuda_check(cudaMemcpy(d_signs.ptr, qjl_signs_flat.data(), qjl_signs_flat.size() * sizeof(int8_t), cudaMemcpyHostToDevice), "cudaMemcpy qjl signs");
+        cuda_check(cudaMemcpy(d_residual_norms.ptr, residual_norms.data(), residual_norms.size() * sizeof(float), cudaMemcpyHostToDevice), "cudaMemcpy residual norms");
+        cuda_check(cudaMemcpy(d_qjl_matrix.ptr, qjl_matrix.data(), qjl_matrix.size() * sizeof(float), cudaMemcpyHostToDevice), "cudaMemcpy qjl matrix");
+
+        const int block = 256;
+        const int project_total = nq * qjl_dim;
+
+        turboquant_project_queries_kernel<<<(project_total + block - 1) / block, block>>>(
+            static_cast<const float *>(d_queries.ptr),
+            static_cast<const float *>(d_qjl_matrix.ptr),
+            static_cast<float *>(d_projected.ptr),
+            nq,
+            qjl_dim,
+            dim);
+        cuda_check(cudaGetLastError(), "turboquant_project_queries_kernel launch");
+
+        turboquant_score_kernel<<<(pair_count + block - 1) / block, block>>>(
+            static_cast<const float *>(d_queries.ptr),
+            static_cast<const float *>(d_dataset.ptr),
+            static_cast<const float *>(d_projected.ptr),
+            static_cast<const float *>(d_mse.ptr),
+            static_cast<const int8_t *>(d_signs.ptr),
+            static_cast<const float *>(d_residual_norms.ptr),
+            static_cast<float *>(d_truth.ptr),
+            static_cast<float *>(d_scores.ptr),
+            nq,
+            nk,
+            dim,
+            qjl_dim,
+            correction_scale);
+        cuda_check(cudaGetLastError(), "turboquant_score_kernel launch");
+        cuda_check(cudaDeviceSynchronize(), "cudaDeviceSynchronize");
+
+        std::vector<float> truth = std::vector<float>(static_cast<size_t>(pair_count));
+        std::vector<float> scores = std::vector<float>(static_cast<size_t>(pair_count));
+        cuda_check(cudaMemcpy(truth.data(), d_truth.ptr, truth.size() * sizeof(float), cudaMemcpyDeviceToHost), "cudaMemcpy truth");
+        cuda_check(cudaMemcpy(scores.data(), d_scores.ptr, scores.size() * sizeof(float), cudaMemcpyDeviceToHost), "cudaMemcpy scores");
+
+        double bias_sum = 0.0;
+        double abs_sum = 0.0;
+        double sq_sum = 0.0;
+        for (int i = 0; i < pair_count; ++i) {
+            const double err = double(scores[i]) - double(truth[i]);
+            bias_sum += err;
+            abs_sum += std::abs(err);
+            sq_sum += err * err;
+        }
+
+        metrics_out.ip_bias_mean = bias_sum / double(pair_count);
+        metrics_out.ip_rmse = std::sqrt(sq_sum / double(pair_count));
+        metrics_out.ip_mae = abs_sum / double(pair_count);
+        return true;
+    } catch (const std::exception & exc) {
+        error_out = exc.what();
+        return false;
+    }
+}
+
+bool ggml_cuda_op_turboquant_exact_supported(const ggml_tensor * dst) {
+    if (dst->op != GGML_OP_CUSTOM || dst->src[0] == nullptr || dst->src[1] == nullptr) {
+        return false;
+    }
+    if (dst->src[0]->type != GGML_TYPE_F32 || dst->type != GGML_TYPE_F32) {
+        return false;
+    }
+    if (dst->src[1]->type != GGML_TYPE_F32 && dst->src[1]->type != GGML_TYPE_I8) {
+        return false;
+    }
+    if (dst->src[1]->type == GGML_TYPE_F32 && dst->src[0]->ne[0] != dst->src[1]->ne[0]) {
+        return false;
+    }
+    return true;
+}
+
+bool ggml_cuda_op_turboquant_pack_supported(const ggml_tensor * dst) {
+    if (dst->op != GGML_OP_CUSTOM || dst->src[0] == nullptr) {
+        return false;
+    }
+    if (dst->type != GGML_TYPE_I8 || dst->src[0]->type != GGML_TYPE_F32) {
+        return false;
+    }
+    if (dst->src[1] != nullptr) {
+        return false;
+    }
+    if (dst->ne[2] != 1 || dst->ne[3] != 1) {
+        return false;
+    }
+    if (dst->src[0]->ne[1] <= 0 || dst->src[0]->ne[2] <= 0) {
+        return false;
+    }
+
+    const int dim = static_cast<int>(dst->src[0]->ne[0]);
+    const int n_head = static_cast<int>(dst->src[0]->ne[1]);
+    const int bits = std::max(2, turboquant_env_int("LLAMA_ARG_TURBOQUANT_BITS", 4));
+    const int explicit_qjl = turboquant_env_int("LLAMA_ARG_TURBOQUANT_QJL_DIM", 0);
+    const int qjl_mult = std::max(1, turboquant_env_int("LLAMA_ARG_TURBOQUANT_QJL_MULT", 2));
+    const int qjl_dim = explicit_qjl > 0 ? explicit_qjl : dim * qjl_mult;
+    const int outlier_channels = std::max(0, turboquant_env_int("LLAMA_ARG_TURBOQUANT_OUTLIERS", std::max(0, dim / 32)));
+    auto params = get_turboquant_exact_device_params(dim, bits, qjl_dim, outlier_channels);
+
+    return dst->ne[0] == int64_t(params->layout.packed_bytes) * n_head;
+}
+
+__global__ void turboquant_fattn_kernel(
+        const float * __restrict__ queries,
+        const float * __restrict__ rotated_queries,
+        const float * __restrict__ projected_queries,
+        const int8_t * __restrict__ packed_keys,
+        const char * __restrict__ values,
+        const half * __restrict__ mask,
+        const float * __restrict__ centroids,
+        float * __restrict__ dst,
+        int dim,
+        int value_dim,
+        int mse_bits,
+        int qjl_dim,
+        int outlier_channels,
+        int n_sign_words,
+        int vec_norm_offset,
+        int residual_norm_offset,
+        int sign_words_offset,
+        int outlier_indices_offset,
+        int outlier_values_offset,
+        int n_q,
+        int n_k,
+        int n_head_q,
+        int n_head_k,
+        int n_stream,
+        int64_t q_nb1,
+        int64_t q_nb2,
+        int64_t q_nb3,
+        int64_t k_nb1,
+        int64_t k_nb2,
+        int64_t k_nb3,
+        int64_t v_nb1,
+        int64_t v_nb2,
+        int64_t v_nb3,
+        int64_t dst_nb1,
+        int64_t dst_nb2,
+        int64_t dst_nb3,
+        int32_t v_type,
+        int64_t mask_ne2,
+        int64_t mask_ne3,
+        int64_t mask_nb1,
+        int64_t mask_nb2,
+        int64_t mask_nb3,
+        float correction_scale,
+        float scale) {
+    constexpr int MAX_VALUES_PER_THREAD = 8;
+
+    const int qrow = blockIdx.x;
+    const int tid = threadIdx.x;
+    const int lane = tid & 31;
+
+    if (qrow >= n_q * n_head_q * n_stream) {
+        return;
+    }
+
+    const int q_tok = qrow % n_q;
+    const int q_head_stream = qrow / n_q;
+    const int q_head = q_head_stream % n_head_q;
+    const int stream = q_head_stream / n_head_q;
+    const int kv_head = (q_head * n_head_k) / n_head_q;
+
+    const char * q_ptr = reinterpret_cast<const char *>(queries)
+            + q_tok * q_nb1
+            + q_head * q_nb2
+            + stream * q_nb3;
+    const float * q = reinterpret_cast<const float *>(q_ptr);
+    const float * rot_q = rotated_queries + qrow * dim;
+    const float * proj_q = projected_queries + qrow * qjl_dim;
+    float proj_q_total = 0.0f;
+    if (tid < 32) {
+        for (int j = lane; j < qjl_dim; j += 32) {
+            proj_q_total += proj_q[j];
+        }
+        proj_q_total = warp_reduce_sum(proj_q_total);
+    }
+
+    int out_count = 0;
+    int out_dims[MAX_VALUES_PER_THREAD];
+    float out_acc[MAX_VALUES_PER_THREAD];
+    for (int d = tid; d < value_dim && out_count < MAX_VALUES_PER_THREAD; d += blockDim.x) {
+        out_dims[out_count] = d;
+        out_acc[out_count] = 0.0f;
+        ++out_count;
+    }
+
+    __shared__ float sh_score;
+    __shared__ float sh_m;
+    __shared__ float sh_l;
+    __shared__ float sh_alpha;
+    __shared__ float sh_beta;
+
+    if (tid == 0) {
+        sh_m = -INFINITY;
+        sh_l = 0.0f;
+        sh_alpha = 0.0f;
+        sh_beta = 0.0f;
+    }
+    __syncthreads();
+
+    for (int kv_tok = 0; kv_tok < n_k; ++kv_tok) {
+        float term1 = 0.0f;
+        float outlier_term = 0.0f;
+        float qjl_ip = 0.0f;
+
+        if (tid < 32) {
+            const int8_t * packed_row = packed_keys
+                    + kv_tok * k_nb1
+                    + kv_head * k_nb2
+                    + stream * k_nb3;
+            const uint8_t * idxs = reinterpret_cast<const uint8_t *>(packed_row);
+            const float vec_norm = *reinterpret_cast<const float *>(packed_row + vec_norm_offset);
+            const float residual_norm = *reinterpret_cast<const float *>(packed_row + residual_norm_offset);
+            const uint32_t * words = reinterpret_cast<const uint32_t *>(packed_row + sign_words_offset);
+            const uint16_t * outlier_indices = outlier_channels > 0 ? reinterpret_cast<const uint16_t *>(packed_row + outlier_indices_offset) : nullptr;
+            const float * outlier_values = outlier_channels > 0 ? reinterpret_cast<const float *>(packed_row + outlier_values_offset) : nullptr;
+
+            for (int i = lane; i < dim; i += 32) {
+                term1 += rot_q[i] * centroids[turboquant_load_code_device(idxs, i, mse_bits)];
+            }
+            term1 = warp_reduce_sum(term1) * vec_norm;
+
+            for (int oi = lane; oi < outlier_channels; oi += 32) {
+                const uint16_t idx = outlier_indices[oi];
+                outlier_term += q[idx] * outlier_values[oi];
+            }
+            outlier_term = warp_reduce_sum(outlier_term);
+
+            qjl_ip = -proj_q_total;
+            for (int w = lane; w < n_sign_words; w += 32) {
+                const uint32_t bits = words[w];
+                const int base = w * 32;
+                for (int b = 0; b < 32; ++b) {
+                    const int j = base + b;
+                    if (j >= qjl_dim) {
+                        break;
+                    }
+                    if (bits & (1u << b)) {
+                        qjl_ip += 2.0f * proj_q[j];
+                    }
+                }
+            }
+            qjl_ip = warp_reduce_sum(qjl_ip);
+
+            if (lane == 0) {
+                float score = (term1 + outlier_term + residual_norm * correction_scale * qjl_ip) * scale;
+                if (mask != nullptr) {
+                    const char * mask_ptr = reinterpret_cast<const char *>(mask)
+                            + kv_tok * int64_t(sizeof(half))
+                            + q_tok * mask_nb1
+                            + (mask_ne2 > 0 ? (q_head % mask_ne2) * mask_nb2 : 0)
+                            + (mask_ne3 > 0 ? (stream % mask_ne3) * mask_nb3 : 0);
+                    score += __half2float(*reinterpret_cast<const half *>(mask_ptr));
+                }
+                const float new_m = fmaxf(sh_m, score);
+                sh_alpha = sh_l > 0.0f ? expf(sh_m - new_m) : 0.0f;
+                sh_beta = expf(score - new_m);
+                sh_m = new_m;
+                sh_l = sh_l * sh_alpha + sh_beta;
+                sh_score = score;
+            }
+        }
+        __syncthreads();
+
+        const char * v_base = reinterpret_cast<const char *>(values)
+                + kv_head * v_nb1
+                + kv_tok * v_nb2
+                + stream * v_nb3;
+        for (int i = 0; i < out_count; ++i) {
+            const float vv = turboquant_load_v_value(v_base, (ggml_type) v_type, out_dims[i]);
+            out_acc[i] = out_acc[i] * sh_alpha + sh_beta * vv;
+        }
+        __syncthreads();
+    }
+
+    const float inv_l = sh_l > 0.0f ? 1.0f / sh_l : 0.0f;
+    for (int i = 0; i < out_count; ++i) {
+        char * out_ptr = reinterpret_cast<char *>(dst)
+                + out_dims[i] * int64_t(sizeof(float))
+                + q_tok * dst_nb1
+                + q_head * dst_nb2
+                + stream * dst_nb3;
+        *reinterpret_cast<float *>(out_ptr) = out_acc[i] * inv_l;
+    }
+}
+
+bool ggml_cuda_op_turboquant_fattn_supported(const ggml_tensor * dst) {
+    if ((dst->op != GGML_OP_CUSTOM && dst->op != GGML_OP_FLASH_ATTN_EXT) || dst->src[0] == nullptr || dst->src[1] == nullptr || dst->src[2] == nullptr) {
+        return false;
+    }
+    if (dst->src[0]->type != GGML_TYPE_F32 || dst->src[1]->type != GGML_TYPE_I8 ||
+            (dst->src[2]->type != GGML_TYPE_F16 &&
+             dst->src[2]->type != GGML_TYPE_Q8_0 &&
+             dst->src[2]->type != GGML_TYPE_Q4_0 &&
+             dst->src[2]->type != GGML_TYPE_Q4_1 &&
+             dst->src[2]->type != GGML_TYPE_Q5_0 &&
+             dst->src[2]->type != GGML_TYPE_Q5_1) ||
+            dst->type != GGML_TYPE_F32) {
+        return false;
+    }
+    if (dst->src[3] != nullptr && dst->src[3]->type != GGML_TYPE_F16) {
+        return false;
+    }
+    return true;
+}
+
+__global__ void turboquant_pack_kcur_compact_kernel(
+        const float * __restrict__ keys,
+        int8_t * __restrict__ packed_out,
+        const float * __restrict__ rotation,
+        const float * __restrict__ boundaries,
+        const float * __restrict__ centroids,
+        const float * __restrict__ qjl_matrix,
+        int dim,
+        int mse_bits,
+        int qjl_dim,
+        int outlier_channels,
+        int n_sign_words,
+        int packed_head_bytes,
+        int vec_norm_offset,
+        int residual_norm_offset,
+        int sign_words_offset,
+        int outlier_indices_offset,
+        int outlier_values_offset,
+        int n_tokens,
+        int n_head,
+        int n_levels,
+        int64_t k_nb1,
+        int64_t k_nb2,
+        int64_t packed_nb1) {
+    const int row = blockIdx.x;
+    const int tid = threadIdx.x;
+    if (row >= n_tokens * n_head) {
+        return;
+    }
+
+    const int token = row / n_head;
+    const int head = row % n_head;
+
+    const char * key_ptr = reinterpret_cast<const char *>(keys)
+            + head * k_nb1
+            + token * k_nb2;
+    const float * key = reinterpret_cast<const float *>(key_ptr);
+    int8_t * packed_row = packed_out
+            + token * packed_nb1
+            + head * packed_head_bytes;
+
+    uint8_t * code_bytes = reinterpret_cast<uint8_t *>(packed_row);
+    float * vec_norm_out = reinterpret_cast<float *>(packed_row + vec_norm_offset);
+    float * residual_norm_out = reinterpret_cast<float *>(packed_row + residual_norm_offset);
+    uint32_t * sign_words_out = reinterpret_cast<uint32_t *>(packed_row + sign_words_offset);
+    uint16_t * outlier_idx_out = outlier_channels > 0 ? reinterpret_cast<uint16_t *>(packed_row + outlier_indices_offset) : nullptr;
+    float * outlier_val_out = outlier_channels > 0 ? reinterpret_cast<float *>(packed_row + outlier_values_offset) : nullptr;
+
+    extern __shared__ float shmem_compact[];
+    float * key_sh = shmem_compact;
+    float * rotated = key_sh + dim;
+    float * residual = rotated + dim;
+    uint16_t * compact_codes = reinterpret_cast<uint16_t *>(residual + dim);
+
+    for (int i = tid; i < dim; i += blockDim.x) {
+        key_sh[i] = key[i];
+    }
+    __syncthreads();
+
+    float norm_sq = 0.0f;
+    for (int i = tid; i < dim; i += blockDim.x) {
+        norm_sq += key_sh[i] * key_sh[i];
+    }
+    norm_sq = block_reduce_sum(norm_sq);
+    const float norm = norm_sq > 0.0f ? sqrtf(norm_sq) : 1.0f;
+    const float inv_norm = 1.0f / norm;
+    if (tid == 0) {
+        *vec_norm_out = norm;
+    }
+
+    for (int r = tid; r < dim; r += blockDim.x) {
+        float acc = 0.0f;
+        const float * rot_row = rotation + r * dim;
+        for (int c = 0; c < dim; ++c) {
+            acc += rot_row[c] * (key_sh[c] * inv_norm);
+        }
+        int idx = 0;
+        while (idx < n_levels - 1 && acc > boundaries[idx]) {
+            ++idx;
+        }
+        compact_codes[r] = static_cast<uint16_t>(idx);
+        rotated[r] = centroids[idx];
+    }
+    __syncthreads();
+
+    for (int byte_idx = tid; byte_idx < vec_norm_offset; byte_idx += blockDim.x) {
+        uint32_t packed = 0;
+        const int first_idx = (byte_idx * 8) / mse_bits;
+        const int last_idx = min(dim - 1, (((byte_idx + 1) * 8) - 1) / mse_bits);
+        for (int idx = first_idx; idx <= last_idx; ++idx) {
+            const int local_bit = idx * mse_bits - byte_idx * 8;
+            const uint32_t code = compact_codes[idx] & ((1u << mse_bits) - 1u);
+            if (local_bit >= 0) {
+                packed |= code << local_bit;
+            } else {
+                packed |= code >> (-local_bit);
+            }
+        }
+        code_bytes[byte_idx] = uint8_t(packed & 0xFFu);
+    }
+    __syncthreads();
+
+    for (int c = tid; c < dim; c += blockDim.x) {
+        float acc = 0.0f;
+        for (int r = 0; r < dim; ++r) {
+            acc += rotation[r * dim + c] * rotated[r];
+        }
+        residual[c] = key_sh[c] - acc * norm;
+    }
+    __syncthreads();
+
+    if (outlier_channels > 0 && tid == 0) {
+        for (int oi = 0; oi < outlier_channels; ++oi) {
+            int best_idx = 0;
+            float best_abs = -1.0f;
+            for (int c = 0; c < dim; ++c) {
+                const float absv = fabsf(residual[c]);
+                if (absv > best_abs) {
+                    best_abs = absv;
+                    best_idx = c;
+                }
+            }
+            outlier_idx_out[oi] = static_cast<uint16_t>(best_idx);
+            outlier_val_out[oi] = residual[best_idx];
+            residual[best_idx] = 0.0f;
+        }
+    }
+    __syncthreads();
+
+    float residual_sq = 0.0f;
+    for (int c = tid; c < dim; c += blockDim.x) {
+        residual_sq += residual[c] * residual[c];
+    }
+    residual_sq = block_reduce_sum(residual_sq);
+    if (tid == 0) {
+        *residual_norm_out = sqrtf(fmaxf(residual_sq, 0.0f));
+    }
+
+    for (int w = tid; w < n_sign_words; w += blockDim.x) {
+        uint32_t bits = 0;
+        for (int b = 0; b < 32; ++b) {
+            const int j = w * 32 + b;
+            if (j >= qjl_dim) {
+                break;
+            }
+            float acc = 0.0f;
+            const float * a = qjl_matrix + j * dim;
+            for (int c = 0; c < dim; ++c) {
+                acc += a[c] * residual[c];
+            }
+            if (acc >= 0.0f) {
+                bits |= (1u << b);
+            }
+        }
+        sign_words_out[w] = bits;
+    }
+}
+
+void ggml_cuda_op_turboquant_pack(ggml_backend_cuda_context & ctx, ggml_tensor * dst) {
+    const ggml_tensor * k = dst->src[0];
+
+    const int dim = static_cast<int>(k->ne[0]);
+    const int src_n_head = static_cast<int>(k->ne[1]);
+    const int n_tokens = static_cast<int>(k->ne[2]);
+    const int bits = std::max(2, turboquant_env_int("LLAMA_ARG_TURBOQUANT_BITS", 4));
+    const int explicit_qjl = turboquant_env_int("LLAMA_ARG_TURBOQUANT_QJL_DIM", 0);
+    const int qjl_mult = std::max(1, turboquant_env_int("LLAMA_ARG_TURBOQUANT_QJL_MULT", 2));
+    const int qjl_dim = explicit_qjl > 0 ? explicit_qjl : dim * qjl_mult;
+    const int outlier_channels = std::max(0, turboquant_env_int("LLAMA_ARG_TURBOQUANT_OUTLIERS", std::max(0, dim / 32)));
+
+    auto params = get_turboquant_exact_device_params(dim, bits, qjl_dim, outlier_channels);
+    const int n_sign_words = (qjl_dim + 31) / 32;
+    const auto & layout = params->layout;
+    const int packed_head_bytes = layout.packed_bytes;
+    GGML_ASSERT(dst->ne[0] % packed_head_bytes == 0);
+    const int dst_n_head = static_cast<int>(dst->ne[0] / packed_head_bytes);
+    GGML_ASSERT(dst->ne[1] == n_tokens);
+    GGML_ASSERT(src_n_head == dst_n_head || src_n_head == 1);
+
+    const int total_rows = n_tokens * dst_n_head;
+    const int compress_threads = 128;
+    const size_t compress_shmem = size_t(3 * dim) * sizeof(float) + size_t(dim) * sizeof(uint16_t);
+    turboquant_pack_kcur_compact_kernel<<<total_rows, compress_threads, compress_shmem, ctx.stream()>>>(
+        static_cast<const float *>(k->data),
+        static_cast<int8_t *>(dst->data),
+        static_cast<const float *>(params->d_rotation.ptr),
+        static_cast<const float *>(params->d_boundaries.ptr),
+        static_cast<const float *>(params->d_centroids.ptr),
+        static_cast<const float *>(params->d_qjl_matrix.ptr),
+        dim,
+        params->mse_bits,
+        qjl_dim,
+        outlier_channels,
+        n_sign_words,
+        packed_head_bytes,
+        layout.vec_norm_offset,
+        layout.residual_norm_offset,
+        layout.sign_words_offset,
+        layout.outlier_indices_offset,
+        layout.outlier_values_offset,
+        n_tokens,
+        dst_n_head,
+        params->n_levels,
+        k->nb[1],
+        k->nb[2],
+        dst->nb[1]);
+    cuda_check(cudaGetLastError(), "turboquant_pack_kcur_compact_kernel launch");
+}
+
+void ggml_cuda_op_turboquant_fattn(ggml_backend_cuda_context & ctx, ggml_tensor * dst) {
+    static bool logged_once = false;
+    if (!logged_once) {
+        GGML_LOG_INFO("%s: executing fused TurboQuant Flash Attention on CUDA\n", __func__);
+        logged_once = true;
+    }
+
+    const ggml_tensor * q = dst->src[0];
+    const ggml_tensor * k = dst->src[1];
+    const ggml_tensor * v = dst->src[2];
+    const ggml_tensor * mask = dst->src[3];
+
+    const int dim = static_cast<int>(q->ne[0]);
+    const int value_dim = static_cast<int>(v->ne[0]);
+    const int n_head_q = static_cast<int>(q->ne[1]);
+    const int n_q = static_cast<int>(q->ne[2]);
+    const int n_stream = static_cast<int>(q->ne[3]);
+    const int n_head_k = static_cast<int>(k->ne[2]);
+    const int n_k = static_cast<int>(k->ne[1]);
+
+    const int bits = std::max(2, turboquant_env_int("LLAMA_ARG_TURBOQUANT_BITS", 4));
+    const int explicit_qjl = turboquant_env_int("LLAMA_ARG_TURBOQUANT_QJL_DIM", 0);
+    const int qjl_mult = std::max(1, turboquant_env_int("LLAMA_ARG_TURBOQUANT_QJL_MULT", 2));
+    const int qjl_dim = explicit_qjl > 0 ? explicit_qjl : dim * qjl_mult;
+    const int outlier_channels = std::max(0, turboquant_env_int("LLAMA_ARG_TURBOQUANT_OUTLIERS", std::max(0, dim / 32)));
+    const auto params = get_turboquant_exact_device_params(dim, bits, qjl_dim, outlier_channels);
+    const auto & layout = params->layout;
+    const int n_sign_words = (qjl_dim + 31) / 32;
+
+    cuda_buffer d_projected_queries;
+    cuda_buffer d_rotated_queries;
+    const int qrow_total = n_q * n_head_q * n_stream;
+    cuda_check(cudaMalloc(&d_projected_queries.ptr, size_t(qrow_total) * qjl_dim * sizeof(float)), "cudaMalloc turboquant fused projected queries");
+    cuda_check(cudaMalloc(&d_rotated_queries.ptr, size_t(qrow_total) * dim * sizeof(float)), "cudaMalloc turboquant fused rotated queries");
+
+    const size_t query_shmem = size_t(dim) * sizeof(float);
+    turboquant_rotate_project_qrows_kernel<<<qrow_total, 128, query_shmem, ctx.stream()>>>(
+        static_cast<const float *>(q->data),
+        static_cast<float *>(d_rotated_queries.ptr),
+        static_cast<float *>(d_projected_queries.ptr),
+        static_cast<const float *>(params->d_rotation.ptr),
+        static_cast<const float *>(params->d_qjl_matrix.ptr),
+        dim,
+        qjl_dim,
+        n_q,
+        n_head_q,
+        n_stream,
+        q->nb[1],
+        q->nb[2],
+        q->nb[3]);
+    cuda_check(cudaGetLastError(), "turboquant_rotate_project_qrows_kernel fused launch");
+
+    const float correction_scale = params->correction_scale;
+    const float scale = 1.0f / sqrtf(float(dim));
+    turboquant_fattn_kernel<<<qrow_total, 128, 0, ctx.stream()>>>(
+        static_cast<const float *>(q->data),
+        static_cast<const float *>(d_rotated_queries.ptr),
+        static_cast<const float *>(d_projected_queries.ptr),
+        static_cast<const int8_t *>(k->data),
+        static_cast<const char *>(v->data),
+        mask ? reinterpret_cast<const half *>(mask->data) : nullptr,
+        static_cast<const float *>(params->d_centroids.ptr),
+        static_cast<float *>(dst->data),
+        dim,
+        value_dim,
+        params->mse_bits,
+        qjl_dim,
+        outlier_channels,
+        n_sign_words,
+        layout.vec_norm_offset,
+        layout.residual_norm_offset,
+        layout.sign_words_offset,
+        layout.outlier_indices_offset,
+        layout.outlier_values_offset,
+        n_q,
+        n_k,
+        n_head_q,
+        n_head_k,
+        n_stream,
+        q->nb[1],
+        q->nb[2],
+        q->nb[3],
+        k->nb[1],
+        k->nb[2],
+        k->nb[3],
+        v->nb[1],
+        v->nb[2],
+        v->nb[3],
+        dst->nb[1],
+        dst->nb[2],
+        dst->nb[3],
+        int32_t(v->type),
+        mask ? mask->ne[2] : 0,
+        mask ? mask->ne[3] : 0,
+        mask ? mask->nb[1] : 0,
+        mask ? mask->nb[2] : 0,
+        mask ? mask->nb[3] : 0,
+        correction_scale,
+        scale);
+    cuda_check(cudaGetLastError(), "turboquant_fattn_kernel launch");
+}
+
+void ggml_cuda_op_turboquant_exact(ggml_backend_cuda_context & ctx, ggml_tensor * dst) {
+    static bool logged_once = false;
+    const bool first_log = !logged_once;
+    if (!logged_once) {
+        GGML_LOG_INFO("%s: executing live TurboQuant exact KQ on CUDA\n", __func__);
+        logged_once = true;
+    }
+
+    const ggml_tensor * q = dst->src[0];
+    const ggml_tensor * k = dst->src[1];
+
+    const int dim = static_cast<int>(q->ne[0]);
+    const int n_q = static_cast<int>(q->ne[1]);
+    const int n_head_q = static_cast<int>(q->ne[2]);
+    const int n_stream = static_cast<int>(q->ne[3]);
+    const int n_k = static_cast<int>(k->ne[1]);
+    const int n_head_k = static_cast<int>(k->ne[2]);
+
+    const int bits = std::max(2, turboquant_env_int("LLAMA_ARG_TURBOQUANT_BITS", 4));
+    const int explicit_qjl = turboquant_env_int("LLAMA_ARG_TURBOQUANT_QJL_DIM", 0);
+    const int qjl_mult = std::max(1, turboquant_env_int("LLAMA_ARG_TURBOQUANT_QJL_MULT", 2));
+    const int qjl_dim = explicit_qjl > 0 ? explicit_qjl : dim * qjl_mult;
+    const int outlier_channels = std::max(0, turboquant_env_int("LLAMA_ARG_TURBOQUANT_OUTLIERS", std::max(0, dim / 32)));
+    const bool cache_enabled = turboquant_env_int("LLAMA_ARG_TURBOQUANT_CACHE", 1) != 0;
+
+    auto params = get_turboquant_exact_device_params(dim, bits, qjl_dim, outlier_channels);
+
+    const int nkv_rows = n_k * n_head_k * n_stream;
+    const int qrow_total = n_q * n_head_q * n_stream;
+    const int n_sign_words = (qjl_dim + 31) / 32;
+    const auto & layout = params->layout;
+    cuda_buffer d_projected_queries;
+    cuda_buffer d_rotated_queries;
+    cuda_check(cudaMalloc(&d_projected_queries.ptr, size_t(qrow_total) * qjl_dim * sizeof(float)), "cudaMalloc turboquant projected queries");
+    cuda_check(cudaMalloc(&d_rotated_queries.ptr, size_t(qrow_total) * dim * sizeof(float)), "cudaMalloc turboquant rotated queries");
+
+    std::shared_ptr<turboquant_exact_key_cache_entry> key_cache;
+    cuda_buffer d_packed_tmp;
+    const int8_t * packed_ptr = nullptr;
+
+    int row_offset = 0;
+    int rows_to_compress = nkv_rows;
+
+    if (k->type == GGML_TYPE_I8) {
+        packed_ptr = static_cast<const int8_t *>(k->data);
+        rows_to_compress = 0;
+    } else if (cache_enabled) {
+        const turboquant_exact_cache_key key = {
+            k->data,
+            dim,
+            bits,
+            qjl_dim,
+            outlier_channels,
+            n_head_k,
+            n_stream,
+        };
+        key_cache = get_turboquant_exact_key_cache(key, nkv_rows, layout.packed_bytes);
+        if (key_cache->last_rows_seen >= 0 && nkv_rows < key_cache->last_rows_seen) {
+            key_cache->compressed_rows = 0;
+        }
+        key_cache->last_rows_seen = nkv_rows;
+        row_offset = std::min(key_cache->compressed_rows, nkv_rows);
+        rows_to_compress = nkv_rows - row_offset;
+        packed_ptr = static_cast<const int8_t *>(key_cache->d_packed.ptr);
+    } else {
+        cuda_check(cudaMalloc(&d_packed_tmp.ptr, size_t(nkv_rows) * layout.packed_bytes), "cudaMalloc turboquant packed rows");
+        packed_ptr = static_cast<const int8_t *>(d_packed_tmp.ptr);
+    }
+
+    const int compress_threads = 128;
+    const size_t compress_shmem = size_t(3 * dim) * sizeof(float) + size_t(dim) * sizeof(uint16_t);
+    if (rows_to_compress > 0) {
+        turboquant_compress_keys_compact_kernel<<<rows_to_compress, compress_threads, compress_shmem, ctx.stream()>>>(
+            static_cast<const float *>(k->data),
+            const_cast<int8_t *>(packed_ptr),
+            static_cast<const float *>(params->d_rotation.ptr),
+            static_cast<const float *>(params->d_boundaries.ptr),
+            static_cast<const float *>(params->d_centroids.ptr),
+            static_cast<const float *>(params->d_qjl_matrix.ptr),
+            dim,
+            params->mse_bits,
+            qjl_dim,
+            outlier_channels,
+            n_sign_words,
+            layout.packed_bytes,
+            layout.vec_norm_offset,
+            layout.residual_norm_offset,
+            layout.sign_words_offset,
+            layout.outlier_indices_offset,
+            layout.outlier_values_offset,
+            nkv_rows,
+            row_offset,
+            params->n_levels,
+            n_k,
+            n_head_k,
+            n_stream,
+            k->nb[1],
+            k->nb[2],
+            k->nb[3],
+            layout.packed_bytes * n_head_k,
+            layout.packed_bytes,
+            layout.packed_bytes * n_head_k * n_k);
+        cuda_check(cudaGetLastError(), "turboquant_compress_keys_compact_kernel launch");
+        if (key_cache) {
+            key_cache->compressed_rows = nkv_rows;
+        }
+    }
+
+    const int block = 128;
+    const size_t query_shmem = size_t(dim) * sizeof(float);
+    turboquant_rotate_project_qrows_kernel<<<qrow_total, 128, query_shmem, ctx.stream()>>>(
+        static_cast<const float *>(q->data),
+        static_cast<float *>(d_rotated_queries.ptr),
+        static_cast<float *>(d_projected_queries.ptr),
+        static_cast<const float *>(params->d_rotation.ptr),
+        static_cast<const float *>(params->d_qjl_matrix.ptr),
+        dim,
+        qjl_dim,
+        n_q,
+        n_head_q,
+        n_stream,
+        q->nb[1],
+        q->nb[2],
+        q->nb[3]);
+    cuda_check(cudaGetLastError(), "turboquant_rotate_project_qrows_kernel launch");
+
+    if (first_log) {
+        const size_t compressed_bytes = size_t(nkv_rows) * layout.packed_bytes;
+        const size_t f16_k_bytes = size_t(nkv_rows) * dim * sizeof(uint16_t);
+        const float ratio = f16_k_bytes > 0 ? float(compressed_bytes) / float(f16_k_bytes) : 1.0f;
+        GGML_LOG_INFO("%s: TurboQuant compact K sidecar = %.2f MiB vs f16-K %.2f MiB (ratio %.3fx, savings %.2f%%)\n",
+                __func__,
+                compressed_bytes / 1024.0 / 1024.0,
+                f16_k_bytes / 1024.0 / 1024.0,
+                ratio,
+                100.0f * (1.0f - ratio));
+    }
+
+    dim3 score_grid(qrow_total, (n_k + block - 1) / block, 1);
+    turboquant_kq_compact_kernel<<<score_grid, block, 0, ctx.stream()>>>(
+        static_cast<const float *>(q->data),
+        static_cast<const float *>(d_rotated_queries.ptr),
+        static_cast<const float *>(d_projected_queries.ptr),
+        packed_ptr,
+        static_cast<const float *>(params->d_centroids.ptr),
+        static_cast<float *>(dst->data),
+        dim,
+        params->mse_bits,
+        qjl_dim,
+        outlier_channels,
+        n_sign_words,
+        layout.packed_bytes,
+        layout.vec_norm_offset,
+        layout.residual_norm_offset,
+        layout.sign_words_offset,
+        layout.outlier_indices_offset,
+        layout.outlier_values_offset,
+        n_q,
+        n_k,
+        n_head_q,
+        n_head_k,
+        n_stream,
+        q->nb[1],
+        q->nb[2],
+        q->nb[3],
+        k->nb[1],
+        k->nb[2],
+        k->nb[3],
+        dst->nb[1],
+        dst->nb[2],
+        dst->nb[3],
+        params->correction_scale);
+    cuda_check(cudaGetLastError(), "turboquant_kq_compact_kernel launch");
+}
