+const char * common_kv_experiment_name(common_kv_experiment experiment) {
+    switch (experiment) {
+        case COMMON_KV_EXPERIMENT_OFF:            return "off";
+        case COMMON_KV_EXPERIMENT_Q8_0:           return "q8_0";
+        case COMMON_KV_EXPERIMENT_Q4_0:           return "q4_0";
+        case COMMON_KV_EXPERIMENT_KQ8_VF16:       return "kq8_vf16";
+        case COMMON_KV_EXPERIMENT_KQ4_VF16:       return "kq4_vf16";
+        case COMMON_KV_EXPERIMENT_KMIX_Q8Q4_VF16: return "kmix_q8q4_vf16";
+        case COMMON_KV_EXPERIMENT_KPACK_Q8_VF16:  return "kpack_q8_vf16";
+        case COMMON_KV_EXPERIMENT_MIXED_Q4K_Q8V:  return "mixed_q4k_q8v";
+        case COMMON_KV_EXPERIMENT_TURBO_PREP:     return "turbo_prep";
+        case COMMON_KV_EXPERIMENT_TURBOQUANT_EXACT:return "turboquant_exact";
+    }
+
+    return "off";
+}
+
+common_kv_experiment common_kv_experiment_from_str(const std::string & value) {
+    std::string normalized = value;
+    std::transform(normalized.begin(), normalized.end(), normalized.begin(), ::tolower);
+
+    if (normalized == "off" || normalized == "none") {
+        return COMMON_KV_EXPERIMENT_OFF;
+    }
+    if (normalized == "q8_0" || normalized == "q8" || normalized == "kv_q8") {
+        return COMMON_KV_EXPERIMENT_Q8_0;
+    }
+    if (normalized == "q4_0" || normalized == "q4" || normalized == "kv_q4") {
+        return COMMON_KV_EXPERIMENT_Q4_0;
+    }
+    if (normalized == "kq8_vf16" || normalized == "q8k_f16v" || normalized == "k_q8_v_f16") {
+        return COMMON_KV_EXPERIMENT_KQ8_VF16;
+    }
+    if (normalized == "kq4_vf16" || normalized == "q4k_f16v" || normalized == "k_q4_v_f16") {
+        return COMMON_KV_EXPERIMENT_KQ4_VF16;
+    }
+    if (normalized == "kmix_q8q4_vf16" || normalized == "kmixed_vf16" || normalized == "k_mixed_q8q4_v_f16") {
+        return COMMON_KV_EXPERIMENT_KMIX_Q8Q4_VF16;
+    }
+    if (normalized == "kpack_q8_vf16" || normalized == "kpack" || normalized == "k_pack_q8_v_f16") {
+        return COMMON_KV_EXPERIMENT_KPACK_Q8_VF16;
+    }
+    if (normalized == "mixed_q4k_q8v" || normalized == "q4k_q8v" || normalized == "kv_mixed_q4k_q8v") {
+        return COMMON_KV_EXPERIMENT_MIXED_Q4K_Q8V;
+    }
+    if (normalized == "turbo_prep" || normalized == "turboquant_prep") {
+        return COMMON_KV_EXPERIMENT_TURBO_PREP;
+    }
+    if (normalized == "turboquant_exact" || normalized == "turbo_exact" || normalized == "turboquant") {
+        return COMMON_KV_EXPERIMENT_TURBOQUANT_EXACT;
+    }
+
+    throw std::invalid_argument("unknown kv experiment preset: " + value);
+}
+
+std::string common_kv_experiment_values() {
+    return "off, q8_0, q4_0, kq8_vf16, kq4_vf16, kmix_q8q4_vf16, kpack_q8_vf16, mixed_q4k_q8v, turbo_prep, turboquant_exact";
+}
+
+namespace {
+common_kv_experiment_resolution resolve_kv_experiment_impl(
+        common_kv_experiment experiment,
+        ggml_type type_k,
+        ggml_type type_v,
+        llama_flash_attn_type flash_attn_type) {
+    auto ensure_flash_for_quantized_v = [&](ggml_type resolved_v) {
+        if (ggml_is_quantized(resolved_v) && flash_attn_type == LLAMA_FLASH_ATTN_TYPE_DISABLED) {
+            return LLAMA_FLASH_ATTN_TYPE_AUTO;
+        }
+        return flash_attn_type;
+    };
+
+    switch (experiment) {
+        case COMMON_KV_EXPERIMENT_OFF:
+            return { type_k, type_v, flash_attn_type, "using explicit cache types" };
+        case COMMON_KV_EXPERIMENT_Q8_0:
+            return { GGML_TYPE_Q8_0, GGML_TYPE_Q8_0, ensure_flash_for_quantized_v(GGML_TYPE_Q8_0), "uniform q8_0 KV cache" };
+        case COMMON_KV_EXPERIMENT_Q4_0:
+            return { GGML_TYPE_Q4_0, GGML_TYPE_Q4_0, ensure_flash_for_quantized_v(GGML_TYPE_Q4_0), "uniform q4_0 KV cache" };
+        case COMMON_KV_EXPERIMENT_KQ8_VF16:
+            return { GGML_TYPE_Q8_0, GGML_TYPE_F16, flash_attn_type, "K-only q8_0 KV experiment with f16 V cache" };
+        case COMMON_KV_EXPERIMENT_KQ4_VF16:
+            return { GGML_TYPE_Q4_0, GGML_TYPE_F16, flash_attn_type, "K-only q4_0 KV experiment with f16 V cache" };
+        case COMMON_KV_EXPERIMENT_KMIX_Q8Q4_VF16:
+            return { GGML_TYPE_Q8_0, GGML_TYPE_F16, flash_attn_type, "layer-mixed K cache experiment (q8 edges, q4 middle) with f16 V cache" };
+        case COMMON_KV_EXPERIMENT_KPACK_Q8_VF16:
+            return { GGML_TYPE_Q8_0, GGML_TYPE_F16, flash_attn_type, "explicit K pack/depack experiment with q8_0 storage and f16 V cache" };
+        case COMMON_KV_EXPERIMENT_MIXED_Q4K_Q8V:
+            return { GGML_TYPE_Q4_0, GGML_TYPE_Q8_0, ensure_flash_for_quantized_v(GGML_TYPE_Q8_0), "mixed K=q4_0, V=q8_0 KV cache" };
+        case COMMON_KV_EXPERIMENT_TURBO_PREP:
+            return { GGML_TYPE_Q4_0, GGML_TYPE_F16, flash_attn_type, "safe pre-TurboQuant KV preset (K=q4_0, V=f16) for backends where quantized V would disable Flash Attention" };
+        case COMMON_KV_EXPERIMENT_TURBOQUANT_EXACT:
+            return { GGML_TYPE_F16, GGML_TYPE_F16, flash_attn_type, "exact TurboQuant attention-score experiment (lab-only, exact layers use custom KQ while other layers may keep Flash Attention)" };
+    }
+
+    return { type_k, type_v, flash_attn_type, "using explicit cache types" };
+}
+
+} // namespace
+
+common_kv_experiment_resolution common_resolve_kv_experiment(
+        common_kv_experiment experiment,
+        ggml_type type_k,
+        ggml_type type_v,
+        llama_flash_attn_type flash_attn_type) {
+    return resolve_kv_experiment_impl(experiment, type_k, type_v, flash_attn_type);
+}
+
 //
 // CPU utils
 //
@@ -1420,8 +1528,25 @@ struct llama_context_params common_context_params_to_llama(const common_params &
     cparams.swa_full          = params.swa_full;
     cparams.kv_unified        = params.kv_unified;
 
-    cparams.type_k = params.cache_type_k;
-    cparams.type_v = params.cache_type_v;
+    const auto kv_resolution = common_resolve_kv_experiment(
+            params.kv_experiment,
+            params.cache_type_k,
+            params.cache_type_v,
+            params.flash_attn_type);
+
+    cparams.type_k = kv_resolution.type_k;
+    cparams.type_v = kv_resolution.type_v;
+    cparams.flash_attn_type = kv_resolution.flash_attn_type;
+
+    if (params.kv_experiment != COMMON_KV_EXPERIMENT_OFF) {
+        LOG_INF("%s: kv experiment '%s' -> K=%s V=%s flash_attn=%s (%s)\n",
+                __func__,
+                common_kv_experiment_name(params.kv_experiment),
+                ggml_type_name(cparams.type_k),
+                ggml_type_name(cparams.type_v),
+                llama_flash_attn_type_name(cparams.flash_attn_type),
+                kv_resolution.note);
+    }
 
     return cparams;
 }
