+            reinterpret_cast<const char *>(dst->op_params) + llama_lab_turboquant_pack_params_offset(),
+            sizeof(pack_params));
+    const int qjl_dim = llama_lab_turboquant_qjl_dim(head_dim);
+    const int outliers = llama_lab_turboquant_outliers(head_dim);
+    const int bits = std::max(1, llama_lab_turboquant_bits(head_dim) - 1);
+    const auto * layer_metadata = llama_lab_turboquant_metadata_for_layer(pack_params.layer_id, n_head);
