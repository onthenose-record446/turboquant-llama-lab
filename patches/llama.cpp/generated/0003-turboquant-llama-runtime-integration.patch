+                ? quantizer.quantize(x, layer_metadata->key_high_precision_indices[(size_t) head])
+                : quantizer.quantize(x);
+        int8_t * dst_row = reinterpret_cast<int8_t *>(dst->data) + size_t(tok) * dst->nb[1] + head * packed_head_bytes;
+        memset(dst_row, 0, packed_head_bytes);
+        uint8_t * code_bytes = reinterpret_cast<uint8_t *>(dst_row);
+        for (int i = 0; i < head_dim; ++i) {
+            llama_lab_turboquant_store_code(code_bytes, i, bits, static_cast<uint8_t>(compressed.mse.indices[i]));
+        }
+        *reinterpret_cast<float *>(dst_row + vec_norm_offset) = compressed.mse.vec_norm;
+        *reinterpret_cast<float *>(dst_row + residual_norm_offset) = compressed.residual_norm;
+        uint32_t * sign_words = reinterpret_cast<uint32_t *>(dst_row + sign_words_offset);
+        for (int j = 0; j < qjl_dim; ++j) {
+            if (compressed.qjl_signs[j] >= 0) {
+                sign_words[j / 32] |= (1u << (j % 32));
+            }
+        }
+        uint16_t * out_idx = outliers > 0 ? reinterpret_cast<uint16_t *>(dst_row + outlier_indices_offset) : nullptr;
+        float * out_val = outliers > 0 ? reinterpret_cast<float *>(dst_row + outlier_values_offset) : nullptr;
+        for (int oi = 0; oi < outliers; ++oi) {
+            if (oi < (int) compressed.outlier_indices.size()) {
+                out_idx[oi] = compressed.outlier_indices[oi];
+                out_val[oi] = compressed.outlier_values[oi];
+            }
