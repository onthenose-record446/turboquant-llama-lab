+    llama_lab::turboquant_init_params params;
+    params.dim = head_dim;
+    params.bits = llama_lab_turboquant_bits(head_dim);
+    params.qjl_dim = qjl_dim;
+    params.outlier_channels = outliers;
+    params.seed = 42;
+    llama_lab::turboquant_prod quantizer(params);
+
+    const int packed_head_bytes = llama_lab_turboquant_packed_head_bytes(head_dim);
+    const int index_bytes = llama_lab_turboquant_index_bytes_for_bits(head_dim, bits);
+    const int vec_norm_offset = llama_lab_align_up_int(index_bytes, 4);
+    const int residual_norm_offset = vec_norm_offset + int(sizeof(float));
+    const int sign_words_offset = llama_lab_align_up_int(residual_norm_offset + int(sizeof(float)), 4);
+    const int outlier_indices_offset = sign_words_offset + ((qjl_dim + 31) / 32) * int(sizeof(uint32_t));
+    const int outlier_values_offset = llama_lab_align_up_int(outlier_indices_offset + outliers * int(sizeof(uint16_t)), 4);
+
+    const int total_rows = n_tokens * n_head;
+    const int row_begin = (total_rows * ith) / nth;
+    const int row_end = (total_rows * (ith + 1)) / nth;
+
+    std::vector<float> x(head_dim, 0.0f);
+    for (int row = row_begin; row < row_end; ++row) {
+        const int tok = row / n_head;
+        const int head = row % n_head;
+        const float * src_ptr = llama_lab_f32_ptr_3d(src, 0, head, tok);
+        std::copy(src_ptr, src_ptr + head_dim, x.begin());
