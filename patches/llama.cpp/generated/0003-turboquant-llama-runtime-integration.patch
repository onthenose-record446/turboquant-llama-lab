+static void llama_lab_turboquant_pack_k_op(ggml_tensor * dst, int ith, int nth, void *) {
+    const ggml_tensor * src = dst->src[0];
+    GGML_ASSERT(src != nullptr);
+    GGML_ASSERT(src->type == GGML_TYPE_F32);
+    GGML_ASSERT(dst->type == GGML_TYPE_I8);
+
+    const int head_dim = static_cast<int>(src->ne[0]);
+    const int n_head = static_cast<int>(src->ne[1]);
+    const int n_tokens = static_cast<int>(src->ne[2]);
