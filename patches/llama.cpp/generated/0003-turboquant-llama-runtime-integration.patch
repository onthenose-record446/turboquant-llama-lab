+static int llama_lab_align_up_int(int value, int alignment) {
+    return ((value + alignment - 1) / alignment) * alignment;
+}
+
+static int llama_lab_turboquant_index_bytes_for_bits(int head_dim, int bits) {
+    return (head_dim * bits + 7) / 8;
+}
+
+static inline void llama_lab_turboquant_store_code(uint8_t * dst, int idx, int bits, uint8_t code) {
+    const int bit_offset = idx * bits;
+    const int byte_offset = bit_offset / 8;
+    const int shift = bit_offset % 8;
+    const uint16_t mask = ((1u << bits) - 1u);
+    uint16_t word = dst[byte_offset];
+    if (shift + bits > 8) {
+        word |= uint16_t(dst[byte_offset + 1]) << 8;
+    }
+    word &= ~(mask << shift);
+    word |= (uint16_t(code) & mask) << shift;
+    dst[byte_offset] = uint8_t(word & 0xFFu);
+    if (shift + bits > 8) {
+        dst[byte_offset + 1] = uint8_t((word >> 8) & 0xFFu);
+    }
+}
+
+static inline uint8_t llama_lab_turboquant_load_code(const uint8_t * src, int idx, int bits) {
+    const int bit_offset = idx * bits;
+    const int byte_offset = bit_offset / 8;
+    const int shift = bit_offset % 8;
+    uint16_t word = src[byte_offset];
+    if (shift + bits > 8) {
+        word |= uint16_t(src[byte_offset + 1]) << 8;
+    }
+    return uint8_t((word >> shift) & ((1u << bits) - 1u));
+}
+
+static int llama_lab_turboquant_packed_head_bytes(int head_dim) {
+    const int bits = std::max(1, llama_lab_turboquant_bits(head_dim) - 1);
+    const int qjl_dim = llama_lab_turboquant_qjl_dim(head_dim);
+    const int outliers = llama_lab_turboquant_outliers(head_dim);
+    const int n_sign_words = (qjl_dim + 31) / 32;
+    const int index_bytes = llama_lab_turboquant_index_bytes_for_bits(head_dim, bits);
+    const int vec_norm_offset = llama_lab_align_up_int(index_bytes, 4);
+    const int residual_norm_offset = vec_norm_offset + int(sizeof(float));
+    const int sign_words_offset = llama_lab_align_up_int(residual_norm_offset + int(sizeof(float)), 4);
+    const int outlier_indices_offset = sign_words_offset + n_sign_words * int(sizeof(uint32_t));
+    const int outlier_values_offset = llama_lab_align_up_int(outlier_indices_offset + outliers * int(sizeof(uint16_t)), 4);
+    return outlier_values_offset + outliers * int(sizeof(float));
+}
