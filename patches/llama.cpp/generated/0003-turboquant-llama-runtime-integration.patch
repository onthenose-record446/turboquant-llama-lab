+static int llama_lab_turboquant_outliers(int head_dim) {
+    const char * raw = getenv("LLAMA_ARG_TURBOQUANT_OUTLIERS");
+    if (raw && raw[0] != '\0') {
+        return std::max(0, std::atoi(raw));
+    }
+    const auto recipe = llama_lab::turboquant_recipe_for_name(llama_lab_turboquant_recipe_name(), head_dim);
+    if (recipe.name != "manual") {
+        return recipe.outlier_channels;
+    }
+    return std::max(0, head_dim / 32);
+}
+
+static int llama_lab_turboquant_bits(int head_dim) {
+    const char * raw = getenv("LLAMA_ARG_TURBOQUANT_BITS");
+    if (raw && raw[0] != '\0') {
+        return std::max(2, std::atoi(raw));
+    }
+    const auto recipe = llama_lab::turboquant_recipe_for_name(llama_lab_turboquant_recipe_name(), head_dim);
+    return std::max(2, recipe.bits);
+}
