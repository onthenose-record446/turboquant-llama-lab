+static int llama_lab_turboquant_qjl_dim(int head_dim) {
+    const int explicit_dim = llama_lab_env_int("LLAMA_ARG_TURBOQUANT_QJL_DIM", 0);
+    if (explicit_dim > 0) {
+        return explicit_dim;
+    }
+    const auto recipe = llama_lab::turboquant_recipe_for_name(llama_lab_turboquant_recipe_name(), head_dim);
+    if (recipe.name != "manual" && recipe.qjl_dim > 0) {
+        return recipe.qjl_dim;
+    }
+    const int multiplier = std::max(1, llama_lab_env_int("LLAMA_ARG_TURBOQUANT_QJL_MULT", 2));
+    return std::max(head_dim, head_dim * multiplier);
+}
