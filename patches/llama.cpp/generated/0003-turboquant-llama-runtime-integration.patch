diff --git a/src/llama-graph.cpp b/src/llama-graph.cpp
index bba747d..42f115b 100644
--- a/src/llama-graph.cpp
+++ b/src/llama-graph.cpp
@@ -9,13 +9,365 @@
 #include "llama-memory-hybrid.h"
 #include "llama-memory-hybrid-iswa.h"
 #include "llama-memory-recurrent.h"
+#include "turboquant.h"
 
 #include <cassert>
+#include <climits>
 #include <cmath>
+#include <cstdlib>
 #include <cstring>
 #include <numeric>
 #include <sstream>
 #include <unordered_set>
+#include <vector>
+
+namespace {
+
+static constexpr const char * LLAMA_LAB_TURBOQUANT_EXACT_MARKER = "llama_lab_turboquant_exact";
+static constexpr const char * LLAMA_LAB_TURBOQUANT_FATTN_MARKER = "llama_lab_turboquant_fattn";
+
+static std::string llama_lab_kv_experiment_name() {
+    const char * kv_experiment_env = std::getenv("LLAMA_ARG_KV_EXPERIMENT");
+    return kv_experiment_env ? kv_experiment_env : "";
+}
+
+static int llama_lab_env_int(const char * name, int default_value) {
+    const char * value = std::getenv(name);
+    if (!value || value[0] == '\0') {
+        return default_value;
+    }
+    return std::max(0, std::atoi(value));
+}
+
+static inline uint8_t llama_lab_turboquant_load_code(const uint8_t * src, int idx, int bits) {
+    const int bit_offset = idx * bits;
+    const int byte_offset = bit_offset / 8;
+    const int shift = bit_offset % 8;
+    uint16_t word = src[byte_offset];
+    if (shift + bits > 8) {
+        word |= uint16_t(src[byte_offset + 1]) << 8;
+    }
+    return uint8_t((word >> shift) & ((1u << bits) - 1u));
+}
+
+static inline int llama_lab_turboquant_index_bytes_for_bits(int head_dim, int bits) {
+    return (head_dim * bits + 7) / 8;
+}
+
+static std::string llama_lab_turboquant_recipe_name() {
+    const char * raw = std::getenv("LLAMA_ARG_TURBOQUANT_RECIPE");
+    return raw ? raw : "";
+}
+
+static bool llama_lab_layer_in_csv_list(const char * raw, int il) {
+    if (!raw || raw[0] == '\0') {
+        return false;
+    }
+
+    const std::string spec(raw);
+    size_t start = 0;
+    while (start < spec.size()) {
+        size_t end = spec.find(',', start);
+        if (end == std::string::npos) {
+            end = spec.size();
+        }
+        std::string token = spec.substr(start, end - start);
+        const size_t first = token.find_first_not_of(" \t");
+        const size_t last = token.find_last_not_of(" \t");
+        if (first != std::string::npos) {
+            token = token.substr(first, last - first + 1);
+            const size_t dash = token.find('-');
+            if (dash != std::string::npos) {
+                const int lo = std::atoi(token.substr(0, dash).c_str());
+                const int hi = std::atoi(token.substr(dash + 1).c_str());
+                if (il >= std::min(lo, hi) && il <= std::max(lo, hi)) {
+                    return true;
+                }
+            } else if (il == std::atoi(token.c_str())) {
+                return true;
+            }
+        }
+        start = end + 1;
+    }
+
+    return false;
+}
+
+static bool llama_lab_use_turboquant_exact(int il) {
+    if (llama_lab_kv_experiment_name() != "turboquant_exact") {
+        return false;
+    }
+
+    const char * layer_list_raw = std::getenv("LLAMA_ARG_TURBOQUANT_LAYER_LIST");
+    if (layer_list_raw && layer_list_raw[0] != '\0') {
+        return llama_lab_layer_in_csv_list(layer_list_raw, il);
+    }
+
+    const char * layer_min_raw = std::getenv("LLAMA_ARG_TURBOQUANT_LAYER_MIN");
+    const char * layer_max_raw = std::getenv("LLAMA_ARG_TURBOQUANT_LAYER_MAX");
+    int layer_min = 0;
+    int layer_max = INT32_MAX;
+    if (layer_min_raw && layer_min_raw[0] != '\0') {
+        layer_min = llama_lab_env_int("LLAMA_ARG_TURBOQUANT_LAYER_MIN", 0);
+    }
+    if (layer_max_raw && layer_max_raw[0] != '\0') {
+        layer_max = llama_lab_env_int("LLAMA_ARG_TURBOQUANT_LAYER_MAX", INT32_MAX);
+    }
+    if ((!layer_min_raw || layer_min_raw[0] == '\0') && (!layer_max_raw || layer_max_raw[0] == '\0')) {
+        const int anchor = llama_lab_env_int("LLAMA_ARG_TURBOQUANT_AUTO_ANCHOR", 3);
+        const char * auto_span_raw = std::getenv("LLAMA_ARG_TURBOQUANT_AUTO_SPAN");
+        if (auto_span_raw && auto_span_raw[0] != '\0') {
+            const int span = std::max(1, llama_lab_env_int("LLAMA_ARG_TURBOQUANT_AUTO_SPAN", 1));
+            layer_min = std::max(0, anchor);
+            layer_max = layer_min + span - 1;
+            return il >= layer_min && il <= layer_max;
+        }
+
+        const int stride = std::max(1, llama_lab_env_int("LLAMA_ARG_TURBOQUANT_AUTO_STRIDE", 4));
+        const int count = std::max(1, llama_lab_env_int("LLAMA_ARG_TURBOQUANT_AUTO_COUNT", 4));
+        for (int i = 0; i < count; ++i) {
+            if (il == anchor + i * stride) {
+                return true;
+            }
+        }
+        return false;
+    }
+    return il >= layer_min && il <= layer_max;
+}
+
+static int llama_lab_turboquant_bits(int head_dim) {
+    const char * raw = std::getenv("LLAMA_ARG_TURBOQUANT_BITS");
+    if (raw && raw[0] != '\0') {
+        return std::max(2, std::atoi(raw));
+    }
+    return std::max(2, llama_lab::turboquant_recipe_for_name(llama_lab_turboquant_recipe_name(), head_dim).bits);
+}
+
+static int llama_lab_turboquant_qjl_dim(int head_dim) {
+    const int explicit_dim = llama_lab_env_int("LLAMA_ARG_TURBOQUANT_QJL_DIM", 0);
+    if (explicit_dim > 0) {
+        return explicit_dim;
+    }
+
+    const auto recipe = llama_lab::turboquant_recipe_for_name(llama_lab_turboquant_recipe_name(), head_dim);
+    if (recipe.name != "manual" && recipe.qjl_dim > 0) {
+        return recipe.qjl_dim;
+    }
+    const int multiplier = std::max(1, llama_lab_env_int("LLAMA_ARG_TURBOQUANT_QJL_MULT", 2));
+    return std::max(head_dim, head_dim * multiplier);
+}
+
+static int llama_lab_turboquant_outliers(int head_dim) {
+    const char * raw = std::getenv("LLAMA_ARG_TURBOQUANT_OUTLIERS");
+    if (raw && raw[0] != '\0') {
+        return std::max(0, std::atoi(raw));
+    }
+    const auto recipe = llama_lab::turboquant_recipe_for_name(llama_lab_turboquant_recipe_name(), head_dim);
+    if (recipe.name != "manual") {
+        return recipe.outlier_channels;
+    }
+    return std::max(0, head_dim / 32);
+}
+
+static int llama_lab_align_up_int(int value, int alignment) {
+    return ((value + alignment - 1) / alignment) * alignment;
+}
+
+static int llama_lab_turboquant_packed_head_bytes(int head_dim) {
+    const int mse_bits = std::max(1, llama_lab_turboquant_bits(head_dim) - 1);
+    const int qjl_dim = llama_lab_turboquant_qjl_dim(head_dim);
+    const int outliers = llama_lab_turboquant_outliers(head_dim);
+    const int n_sign_words = (qjl_dim + 31) / 32;
+    const int index_bytes = llama_lab_turboquant_index_bytes_for_bits(head_dim, mse_bits);
+    const int vec_norm_offset = llama_lab_align_up_int(index_bytes, 4);
+    const int residual_norm_offset = vec_norm_offset + int(sizeof(float));
+    const int sign_words_offset = llama_lab_align_up_int(residual_norm_offset + int(sizeof(float)), 4);
+    const int outlier_indices_offset = sign_words_offset + n_sign_words * int(sizeof(uint32_t));
+    const int outlier_values_offset = llama_lab_align_up_int(outlier_indices_offset + outliers * int(sizeof(uint16_t)), 4);
+    return outlier_values_offset + outliers * int(sizeof(float));
+}
+
+static const float * llama_lab_f32_ptr_4d(
+        const ggml_tensor * tensor,
+        int64_t i0,
+        int64_t i1,
+        int64_t i2,
+        int64_t i3) {
+    return reinterpret_cast<const float *>(
+            reinterpret_cast<const char *>(tensor->data)
+            + i0 * tensor->nb[0]
+            + i1 * tensor->nb[1]
+            + i2 * tensor->nb[2]
+            + i3 * tensor->nb[3]);
+}
+
+static float * llama_lab_f32_ptr_4d(
+        ggml_tensor * tensor,
+        int64_t i0,
+        int64_t i1,
+        int64_t i2,
+        int64_t i3) {
+    return reinterpret_cast<float *>(
+            reinterpret_cast<char *>(tensor->data)
+            + i0 * tensor->nb[0]
+            + i1 * tensor->nb[1]
+            + i2 * tensor->nb[2]
+            + i3 * tensor->nb[3]);
+}
+
+static void llama_lab_turboquant_exact_kq_op(ggml_tensor * dst, int ith, int nth, void *) {
+    static bool logged_once = false;
+    if (!logged_once && ith == 0) {
+        LLAMA_LOG_INFO("%s: executing exact TurboQuant KQ on CPU custom op\n", __func__);
+        logged_once = true;
+    }
+
+    const ggml_tensor * q = dst->src[0];
+    const ggml_tensor * k = dst->src[1];
+
+    GGML_ASSERT(q != nullptr && k != nullptr);
+    GGML_ASSERT(q->type == GGML_TYPE_F32);
+    GGML_ASSERT(k->type == GGML_TYPE_F32 || k->type == GGML_TYPE_I8);
+    GGML_ASSERT(dst->type == GGML_TYPE_F32);
+
+    const int64_t head_dim  = q->ne[0];
+    const int64_t q_tokens  = q->ne[1];
+    const int64_t q_heads   = q->ne[2];
+    const int64_t streams   = q->ne[3];
+    const int64_t kv_tokens = k->ne[1];
+    const int64_t kv_heads  = k->ne[2];
+
+    GGML_ASSERT(streams == k->ne[3]);
+    GGML_ASSERT(dst->ne[0] == kv_tokens);
+    GGML_ASSERT(dst->ne[1] == q_tokens);
+    GGML_ASSERT(dst->ne[2] == q_heads);
+    GGML_ASSERT(dst->ne[3] == streams);
+
+    const int prod_bits = llama_lab_turboquant_bits((int) head_dim);
+    const int mse_bits = std::max(1, prod_bits - 1);
+    const int qjl_dim = llama_lab_turboquant_qjl_dim((int) head_dim);
+    const int outlier_channels = llama_lab_turboquant_outliers((int) head_dim);
+    const int n_sign_words = (qjl_dim + 31) / 32;
+    const int packed_head_bytes = llama_lab_turboquant_packed_head_bytes((int) head_dim);
+
+    bool merged_packed_heads = false;
+    int64_t kv_heads_effective = kv_heads;
+    if (k->type == GGML_TYPE_F32) {
+        GGML_ASSERT(head_dim == k->ne[0]);
+    } else {
+        if (k->ne[0] == packed_head_bytes) {
+            kv_heads_effective = kv_heads;
+        } else {
+            LLAMA_LOG_WARN("%s: packed CPU exact K layout mismatch: q(head_dim=%lld q_heads=%lld streams=%lld) "
+                           "k(ne=[%lld,%lld,%lld,%lld] nb=[%zu,%zu,%zu,%zu]) packed_head_bytes=%d kv_heads=%lld\n",
+                    __func__,
+                    (long long) head_dim,
+                    (long long) q_heads,
+                    (long long) streams,
+                    (long long) k->ne[0],
+                    (long long) k->ne[1],
+                    (long long) k->ne[2],
+                    (long long) k->ne[3],
+                    (size_t) k->nb[0],
+                    (size_t) k->nb[1],
+                    (size_t) k->nb[2],
+                    (size_t) k->nb[3],
+                    packed_head_bytes,
+                    (long long) kv_heads);
+            GGML_ASSERT(k->ne[0] % packed_head_bytes == 0);
+            merged_packed_heads = true;
+            kv_heads_effective = std::max<int64_t>(1, k->ne[0] / packed_head_bytes);
+        }
+    }
+
+    llama_lab::turboquant_init_params params;
+    params.dim = (int) head_dim;
+    params.bits = prod_bits;
+    params.qjl_dim = qjl_dim;
+    params.outlier_channels = outlier_channels;
+    params.seed = 42;
+
+    llama_lab::turboquant_prod quantizer(params);
+
+    const int64_t total_jobs = streams * q_heads;
+    const int64_t job_begin = (total_jobs * ith) / nth;
+    const int64_t job_end = (total_jobs * (ith + 1)) / nth;
+
+    std::vector<float> key_vec((size_t) head_dim);
+    std::vector<float> query_vec((size_t) head_dim);
+    std::vector<llama_lab::turboquant_prod_compressed> compressed_keys((size_t) kv_tokens);
+
+    for (int64_t job = job_begin; job < job_end; ++job) {
+        const int64_t stream = job / q_heads;
+        const int64_t q_head = job % q_heads;
+        const int64_t kv_head = std::min<int64_t>(kv_heads_effective - 1, (q_head * kv_heads_effective) / std::max<int64_t>(1, q_heads));
+
+        for (int64_t tk = 0; tk < kv_tokens; ++tk) {
+            if (k->type == GGML_TYPE_F32) {
+                const float * key_ptr = llama_lab_f32_ptr_4d(k, 0, tk, kv_head, stream);
+                std::memcpy(key_vec.data(), key_ptr, sizeof(float) * (size_t) head_dim);
+                compressed_keys[(size_t) tk] = quantizer.quantize(key_vec);
+            } else {
+                const char * packed_base = reinterpret_cast<const char *>(k->data)
+                        + tk * k->nb[1]
+                        + stream * k->nb[3];
+                const char * packed_row = merged_packed_heads
+                        ? packed_base + kv_head * packed_head_bytes
+                        : packed_base + kv_head * k->nb[2];
+                llama_lab::turboquant_prod_compressed compressed;
+                compressed.mse.indices.resize((size_t) head_dim);
+                const uint8_t * idxs = reinterpret_cast<const uint8_t *>(packed_row);
+                const int index_bytes = llama_lab_turboquant_index_bytes_for_bits((int) head_dim, mse_bits);
+                const int vec_norm_offset = llama_lab_align_up_int(index_bytes, 4);
+                const int residual_norm_offset = vec_norm_offset + int(sizeof(float));
+                const int sign_words_offset = llama_lab_align_up_int(residual_norm_offset + int(sizeof(float)), 4);
+                const int outlier_indices_offset = sign_words_offset + n_sign_words * int(sizeof(uint32_t));
+                const int outlier_values_offset = llama_lab_align_up_int(outlier_indices_offset + outlier_channels * int(sizeof(uint16_t)), 4);
+
+                compressed.mse.vec_norm = *reinterpret_cast<const float *>(packed_row + vec_norm_offset);
+                compressed.residual_norm = *reinterpret_cast<const float *>(packed_row + residual_norm_offset);
+
+                compressed.qjl_signs.assign((size_t) qjl_dim, int8_t(-1));
+                const uint32_t * words = reinterpret_cast<const uint32_t *>(packed_row + sign_words_offset);
+                for (int j = 0; j < qjl_dim; ++j) {
+                    const uint32_t word = words[j / 32];
+                    compressed.qjl_signs[(size_t) j] = (word & (1u << (j % 32))) ? int8_t(1) : int8_t(-1);
+                }
+
+                compressed.outlier_indices.resize((size_t) outlier_channels);
+                compressed.outlier_values.resize((size_t) outlier_channels);
+                const uint16_t * packed_outlier_indices = outlier_channels > 0 ? reinterpret_cast<const uint16_t *>(packed_row + outlier_indices_offset) : nullptr;
+                const float * packed_outlier_values = outlier_channels > 0 ? reinterpret_cast<const float *>(packed_row + outlier_values_offset) : nullptr;
+                for (int oi = 0; oi < outlier_channels; ++oi) {
+                    compressed.outlier_indices[(size_t) oi] = packed_outlier_indices[oi];
+                    compressed.outlier_values[(size_t) oi] = packed_outlier_values[oi];
+                }
+
+                compressed_keys[(size_t) tk] = std::move(compressed);
+                for (int64_t i = 0; i < head_dim; ++i) {
+                    compressed_keys[(size_t) tk].mse.indices[(size_t) i] = llama_lab_turboquant_load_code(idxs, (int) i, mse_bits);
+                }
+            }
+        }
+
+        for (int64_t tq = 0; tq < q_tokens; ++tq) {
+            const float * query_ptr = llama_lab_f32_ptr_4d(q, 0, tq, q_head, stream);
+            float * dst_ptr = llama_lab_f32_ptr_4d(dst, 0, tq, q_head, stream);
+            std::memcpy(query_vec.data(), query_ptr, sizeof(float) * (size_t) head_dim);
+
+            for (int64_t tk = 0; tk < kv_tokens; ++tk) {
+                dst_ptr[tk] = (float) quantizer.inner_product(query_vec, compressed_keys[(size_t) tk]);
+            }
+        }
+    }
+}
