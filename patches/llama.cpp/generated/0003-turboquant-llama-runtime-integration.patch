+static ggml_type llama_lab_turboquant_v_type() {
+    const char * raw = getenv("LLAMA_ARG_TURBOQUANT_V_TYPE");
+    if (!raw || raw[0] == '\0') {
+        return GGML_TYPE_F16;
+    }
+
+    std::string spec(raw);
+    std::transform(spec.begin(), spec.end(), spec.begin(), [](unsigned char ch) {
+        return (char) std::tolower(ch);
+    });
+
+    if (spec == "q8_0" || spec == "q8") {
+        return GGML_TYPE_Q8_0;
+    }
+    if (spec == "q4_0" || spec == "q4") {
+        return GGML_TYPE_Q4_0;
+    }
+    if (spec == "q4_1") {
+        return GGML_TYPE_Q4_1;
+    }
+    if (spec == "q5_0" || spec == "q5") {
+        return GGML_TYPE_Q5_0;
+    }
+    if (spec == "q5_1") {
+        return GGML_TYPE_Q5_1;
+    }
+    if (spec == "f16" || spec == "fp16" || spec == "half") {
+        return GGML_TYPE_F16;
+    }
+
+    LLAMA_LOG_WARN("%s: unsupported LLAMA_ARG_TURBOQUANT_V_TYPE=%s, defaulting to f16\n", __func__, raw);
+    return GGML_TYPE_F16;
+}
