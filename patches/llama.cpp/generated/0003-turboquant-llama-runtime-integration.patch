+static std::vector<int32_t> llama_lab_select_last_dense_layers(const std::vector<int32_t> & candidates, int count) {
+    if (candidates.empty() || count <= 0) {
+        return {};
+    }
+    if (count >= (int) candidates.size()) {
+        return candidates;
+    }
+    return std::vector<int32_t>(candidates.end() - count, candidates.end());
+}
+
+static std::vector<int32_t> llama_lab_select_first_layers(const std::vector<int32_t> & candidates, int count) {
+    if (candidates.empty() || count <= 0) {
+        return {};
+    }
+    if (count >= (int) candidates.size()) {
+        return candidates;
+    }
+    return std::vector<int32_t>(candidates.begin(), candidates.begin() + count);
+}
+
+static std::vector<int32_t> llama_lab_select_last_sparse_layers(const std::vector<int32_t> & candidates, int count, int window_mult) {
+    if (candidates.empty() || count <= 0) {
+        return {};
+    }
+    if ((int) candidates.size() <= count) {
+        return candidates;
+    }
+
+    const int window = std::min<int>(candidates.size(), std::max(count, count * std::max(1, window_mult)));
+    const int start = std::max(0, (int) candidates.size() - window);
+    if (count == 1) {
+        return { candidates.back() };
+    }
+
+    std::set<int32_t> picked;
+    for (int i = 0; i < count; ++i) {
+        const double ratio = count > 1 ? double(i) / double(count - 1) : 1.0;
+        const int local = std::min(window - 1, std::max(0, (int) std::llround(ratio * double(window - 1))));
+        picked.insert(candidates[start + local]);
+    }
+
+    std::vector<int32_t> out;
+    out.reserve(picked.size());
+    for (int32_t il : picked) {
+        out.push_back(il);
+    }
+    return out;
+}
